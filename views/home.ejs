<%
  layout = 'layouts/public';
  title  = 'InstaFlow - Grow Your Instagram on Autopilot';
%>

<!-- =====================================================================
     HERO SECTION
     ===================================================================== -->
<section class="hero-gradient pt-20 pb-28 px-4 sm:px-6 lg:px-8 overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Copy -->
      <div class="text-center lg:text-left">
        <!-- Badge -->
        <div class="inline-flex items-center space-x-2 bg-blue-50 border border-blue-200 text-blue-700 text-xs font-semibold px-4 py-2 rounded-full mb-6">
          <span class="w-2 h-2 bg-blue-500 rounded-full animate-pulse"></span>
          <span>Trusted by 5,000+ creators worldwide</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black leading-tight tracking-tight text-gray-900 mb-6">
          Grow Your Instagram
          <span class="gradient-text block">on Autopilot</span>
        </h1>

        <p class="text-lg sm:text-xl text-gray-600 mb-8 leading-relaxed max-w-xl mx-auto lg:mx-0">
          Turn Instagram comments and DMs into sales with intelligent automation.
          Set up keyword triggers, send personalised DMs, and track results — all
          without touching the app.
        </p>

        <!-- CTA row -->
        <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start space-y-3 sm:space-y-0 sm:space-x-4 mb-10">
          <a href="/auth/register"
             class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 text-base font-bold text-white bg-gradient-to-r from-blue-600 to-violet-600 rounded-xl hover:from-blue-700 hover:to-violet-700 transition-all shadow-lg shadow-blue-200 hover:shadow-xl hover:shadow-blue-300 hover:-translate-y-0.5 transform">
            Get Started Free
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
          <a href="#how-it-works"
             class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-gray-700 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 hover:border-gray-300 transition-all shadow-sm">
            <svg class="w-5 h-5 mr-2 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            See How It Works
          </a>
        </div>

        <!-- Trust micro-copy -->
        <div class="flex items-center justify-center lg:justify-start space-x-6 text-sm text-gray-500">
          <div class="flex items-center space-x-1.5">
            <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            <span>No credit card required</span>
          </div>
          <div class="flex items-center space-x-1.5">
            <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            <span>Cancel anytime</span>
          </div>
        </div>
      </div>

      <!-- Dashboard mockup placeholder -->
      <div class="hidden lg:flex items-center justify-center">
        <div class="relative w-full max-w-lg">
          <!-- Glow effect -->
          <div class="absolute inset-0 bg-gradient-to-r from-blue-400 to-violet-400 rounded-3xl blur-3xl opacity-20 scale-105"></div>
          <!-- Mockup frame -->
          <div class="relative bg-white rounded-2xl shadow-2xl border border-gray-100 overflow-hidden">
            <!-- Browser bar -->
            <div class="bg-gray-50 border-b border-gray-100 px-4 py-3 flex items-center space-x-2">
              <div class="w-3 h-3 rounded-full bg-red-400"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
              <div class="w-3 h-3 rounded-full bg-green-400"></div>
              <div class="flex-1 bg-gray-200 rounded-md h-5 mx-4 flex items-center justify-center">
                <span class="text-xs text-gray-400 font-medium">app.instaflow.io/dashboard</span>
              </div>
            </div>

            <!-- Mock dashboard content -->
            <div class="p-6">
              <div class="flex items-center justify-between mb-5">
                <div>
                  <div class="w-36 h-4 bg-gray-200 rounded animate-pulse"></div>
                  <div class="w-24 h-3 bg-gray-100 rounded mt-2 animate-pulse"></div>
                </div>
                <div class="flex space-x-2">
                  <div class="w-20 h-8 bg-blue-100 rounded-lg animate-pulse"></div>
                  <div class="w-28 h-8 bg-blue-500 rounded-lg animate-pulse opacity-75"></div>
                </div>
              </div>

              <!-- Stats row -->
              <div class="grid grid-cols-4 gap-3 mb-5">
                <% ['blue', 'green', 'purple', 'orange'].forEach(function(color) { %>
                <div class="bg-<%= color === 'orange' ? 'orange' : color %>-50 rounded-xl p-3 text-center">
                  <div class="w-full h-5 bg-<%= color === 'orange' ? 'orange' : color %>-200 rounded mb-2 animate-pulse"></div>
                  <div class="w-12 h-3 bg-<%= color === 'orange' ? 'orange' : color %>-100 rounded mx-auto animate-pulse"></div>
                </div>
                <% }) %>
              </div>

              <!-- Chart placeholder -->
              <div class="bg-gray-50 rounded-xl p-4 mb-4">
                <div class="flex items-end space-x-2 h-24">
                  <% [40, 65, 45, 80, 60, 90, 70, 85, 55, 95, 75, 100].forEach(function(h) { %>
                  <div class="flex-1 bg-gradient-to-t from-blue-500 to-blue-300 rounded-t" style="height: <%= h %>%;opacity:0.7;"></div>
                  <% }) %>
                </div>
              </div>

              <!-- Automation rows -->
              <% [1,2,3].forEach(function(i) { %>
              <div class="flex items-center space-x-3 py-2 border-b border-gray-50 last:border-0">
                <div class="w-8 h-8 bg-blue-100 rounded-lg animate-pulse"></div>
                <div class="flex-1">
                  <div class="w-32 h-3 bg-gray-200 rounded animate-pulse"></div>
                  <div class="w-20 h-2 bg-gray-100 rounded mt-1 animate-pulse"></div>
                </div>
                <div class="w-12 h-5 bg-green-100 rounded-full animate-pulse"></div>
              </div>
              <% }) %>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- =====================================================================
     SOCIAL PROOF — numbers banner
     ===================================================================== -->
<section class="bg-white py-12 border-y border-gray-100">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <div>
        <div class="text-3xl font-black text-gray-900 mb-1">5,000+</div>
        <div class="text-sm text-gray-500 font-medium">Active Creators</div>
      </div>
      <div>
        <div class="text-3xl font-black text-gray-900 mb-1">12M+</div>
        <div class="text-sm text-gray-500 font-medium">DMs Sent</div>
      </div>
      <div>
        <div class="text-3xl font-black text-gray-900 mb-1">94%</div>
        <div class="text-sm text-gray-500 font-medium">Delivery Rate</div>
      </div>
      <div>
        <div class="text-3xl font-black text-gray-900 mb-1">4.9/5</div>
        <div class="text-sm text-gray-500 font-medium">Average Rating</div>
      </div>
    </div>
  </div>
</section>

<!-- =====================================================================
     FEATURES SECTION
     ===================================================================== -->
<section id="features" class="py-24 px-4 sm:px-6 lg:px-8 bg-white">
  <div class="max-w-7xl mx-auto">

    <!-- Section header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center space-x-2 bg-blue-50 text-blue-600 text-xs font-semibold px-4 py-2 rounded-full mb-4 uppercase tracking-wider">
        Everything you need
      </div>
      <h2 class="text-3xl sm:text-4xl font-black text-gray-900 mb-4">
        Powerful automation features
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        From keyword-triggered DMs to advanced campaign scheduling, InstaFlow has every tool you need to grow on Instagram without the manual work.
      </p>
    </div>

    <!-- Feature cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

      <!-- Feature 1: Automated DMs -->
      <div class="feature-card bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
        <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Automated DMs</h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          Send personalised direct messages automatically when someone comments, mentions you, or sends a story reply. Deliver value at scale without lifting a finger.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="text-xs bg-blue-50 text-blue-600 font-medium px-2.5 py-1 rounded-full">Comment triggers</span>
          <span class="text-xs bg-blue-50 text-blue-600 font-medium px-2.5 py-1 rounded-full">Story replies</span>
        </div>
      </div>

      <!-- Feature 2: Comment Triggers -->
      <div class="feature-card bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
        <div class="w-12 h-12 bg-violet-100 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Comment Triggers</h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          Define keywords that fire automations when detected in post comments. Convert post engagement into leads automatically — perfect for giveaways and promotions.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="text-xs bg-violet-50 text-violet-600 font-medium px-2.5 py-1 rounded-full">Keyword matching</span>
          <span class="text-xs bg-violet-50 text-violet-600 font-medium px-2.5 py-1 rounded-full">Regex support</span>
        </div>
      </div>

      <!-- Feature 3: Smart Campaigns -->
      <div class="feature-card bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
        <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Smart Campaigns</h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          Broadcast DM campaigns to segmented contact lists on a schedule. Personalise with merge tags, A/B test messages, and track open and reply rates.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="text-xs bg-green-50 text-green-600 font-medium px-2.5 py-1 rounded-full">Segmentation</span>
          <span class="text-xs bg-green-50 text-green-600 font-medium px-2.5 py-1 rounded-full">Scheduling</span>
        </div>
      </div>

      <!-- Feature 4: Contact Management -->
      <div class="feature-card bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
        <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Contact Management</h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          Build a rich CRM of your Instagram followers. Tag contacts, add notes, track custom fields, and segment by engagement, location, or any custom criteria.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="text-xs bg-orange-50 text-orange-600 font-medium px-2.5 py-1 rounded-full">Tags &amp; segments</span>
          <span class="text-xs bg-orange-50 text-orange-600 font-medium px-2.5 py-1 rounded-full">CSV import</span>
        </div>
      </div>

      <!-- Feature 5: Analytics Dashboard -->
      <div class="feature-card bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
        <div class="w-12 h-12 bg-pink-100 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Analytics Dashboard</h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          Get a bird's-eye view of all automation activity. Track trigger rates, DM delivery, reply rates, follower growth and campaign ROI in real time.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="text-xs bg-pink-50 text-pink-600 font-medium px-2.5 py-1 rounded-full">Real-time charts</span>
          <span class="text-xs bg-pink-50 text-pink-600 font-medium px-2.5 py-1 rounded-full">CSV export</span>
        </div>
      </div>

      <!-- Feature 6: Link-in-Bio -->
      <div class="feature-card bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
        <div class="w-12 h-12 bg-teal-100 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Link-in-Bio Pages</h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          Create beautiful, branded link pages with multiple links, custom themes, and click tracking. Replace that single bio link with an entire micro-website.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="text-xs bg-teal-50 text-teal-600 font-medium px-2.5 py-1 rounded-full">Custom themes</span>
          <span class="text-xs bg-teal-50 text-teal-600 font-medium px-2.5 py-1 rounded-full">Click analytics</span>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- =====================================================================
     HOW IT WORKS
     ===================================================================== -->
<section id="how-it-works" class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-50">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <div class="inline-flex items-center space-x-2 bg-violet-50 text-violet-600 text-xs font-semibold px-4 py-2 rounded-full mb-4 uppercase tracking-wider">
        Simple setup
      </div>
      <h2 class="text-3xl sm:text-4xl font-black text-gray-900 mb-4">
        Get started in minutes
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        No technical knowledge required. Connect your account, configure your automations, and watch engagement grow.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <!-- Step 1 -->
      <div class="text-center">
        <div class="relative inline-flex mb-6">
          <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl flex items-center justify-center shadow-lg shadow-blue-200">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
            </svg>
          </div>
          <div class="absolute -top-2 -right-2 w-7 h-7 bg-white border-2 border-blue-200 rounded-full flex items-center justify-center text-xs font-black text-blue-600">1</div>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Connect Instagram</h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          Securely connect your Instagram Business or Creator account via official Meta OAuth in under 60 seconds.
        </p>
      </div>

      <!-- Arrow -->
      <div class="hidden md:flex items-center justify-center">
        <svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </div>

      <!-- Step 2 -->
      <div class="text-center">
        <div class="relative inline-flex mb-6">
          <div class="w-16 h-16 bg-gradient-to-br from-violet-500 to-violet-600 rounded-2xl flex items-center justify-center shadow-lg shadow-violet-200">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <div class="absolute -top-2 -right-2 w-7 h-7 bg-white border-2 border-violet-200 rounded-full flex items-center justify-center text-xs font-black text-violet-600">2</div>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Set Up Automations</h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          Choose from ready-made templates or build custom flows with keyword triggers, DM sequences, and follow-up delays.
        </p>
      </div>

      <!-- Arrow -->
      <div class="hidden md:flex items-center justify-center col-start-3 col-end-3 row-start-1">
      </div>

    </div>

    <!-- Step 3 on its own row centred -->
    <div class="mt-10 flex flex-col items-center">
      <div class="hidden md:block w-px h-10 bg-gray-200 mb-6"></div>
      <div class="text-center max-w-xs">
        <div class="relative inline-flex mb-6">
          <div class="w-16 h-16 bg-gradient-to-br from-green-500 to-emerald-600 rounded-2xl flex items-center justify-center shadow-lg shadow-green-200">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
          </div>
          <div class="absolute -top-2 -right-2 w-7 h-7 bg-white border-2 border-green-200 rounded-full flex items-center justify-center text-xs font-black text-green-600">3</div>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Watch It Grow</h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          Your automations run 24/7 while you focus on creating content. Track results in real time and optimise with data-driven insights.
        </p>
      </div>
    </div>

  </div>
</section>

<!-- =====================================================================
     TESTIMONIALS
     ===================================================================== -->
<section id="testimonials" class="py-24 px-4 sm:px-6 lg:px-8 bg-white">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <div class="inline-flex items-center space-x-2 bg-yellow-50 text-yellow-600 text-xs font-semibold px-4 py-2 rounded-full mb-4 uppercase tracking-wider">
        Social proof
      </div>
      <h2 class="text-3xl sm:text-4xl font-black text-gray-900 mb-4">
        Loved by 5,000+ creators
      </h2>
      <div class="flex items-center justify-center space-x-1 mb-4">
        <% for(var i=0;i<5;i++) { %>
        <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
