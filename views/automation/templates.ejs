<%
  layout    = 'layouts/main';
  title     = 'Automation Templates';
  activePage = 'automations';
%>

<!-- Page header -->
<div class="mb-8 flex items-start justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Automation Templates</h1>
    <p class="text-gray-500 mt-1">Start from a pre-built template and customise it to your needs.</p>
  </div>
  <a href="/dashboard/automations/create" class="btn-secondary text-sm flex items-center space-x-2">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    <span>Build from scratch</span>
  </a>
</div>

<!-- Search + filter bar -->
<div class="card p-4 mb-6 flex flex-col sm:flex-row items-start sm:items-center space-y-3 sm:space-y-0 sm:space-x-4">
  <!-- Search -->
  <div class="relative flex-1 w-full">
    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
    </svg>
    <input id="template-search"
           type="search"
           placeholder="Search templates…"
           class="w-full pl-9 pr-4 py-2 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
           autocomplete="off">
  </div>

  <!-- Category filter buttons -->
  <div class="flex flex-wrap items-center gap-2" id="category-filters">
    <button class="filter-btn active text-xs font-medium px-3 py-1.5 rounded-full bg-blue-600 text-white transition-all" data-category="all">
      All
    </button>
    <% const categories = ['DM Automation', 'Comment Trigger', 'Lead Generation', 'Customer Service', 'E-commerce', 'Engagement']; %>
    <% categories.forEach(function(cat) { %>
    <button class="filter-btn text-xs font-medium px-3 py-1.5 rounded-full bg-gray-100 text-gray-700 hover:bg-gray-200 transition-all"
            data-category="<%= cat %>">
      <%= cat %>
    </button>
    <% }) %>
  </div>
</div>

<!-- Templates grid -->
<% if (!templates || templates.length === 0) { %>
<div class="text-center py-20">
  <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
    <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
    </svg>
  </div>
  <h3 class="text-lg font-semibold text-gray-900 mb-1">No templates found</h3>
  <p class="text-sm text-gray-500 mb-6">Check back soon or build an automation from scratch.</p>
  <a href="/dashboard/automations/create" class="btn-primary text-sm">Build from scratch</a>
</div>
<% } else { %>

<div id="templates-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

  <% templates.forEach(function(template) { %>
  <%
    const triggerLabels = {
      'comment_keyword': 'Comment keyword',
      'dm_keyword':      'DM keyword',
      'story_reply':     'Story reply',
      'new_follower':    'New follower',
      'post_mention':    'Post mention',
      'manual':          'Manual',
    };
    const categoryColors = {
      'DM Automation':    'bg-blue-100 text-blue-700',
      'Comment Trigger':  'bg-violet-100 text-violet-700',
      'Lead Generation':  'bg-green-100 text-green-700',
      'Customer Service': 'bg-orange-100 text-orange-700',
      'E-commerce':       'bg-pink-100 text-pink-700',
      'Engagement':       'bg-yellow-100 text-yellow-700',
    };
    const catClass = categoryColors[template.category] || 'bg-gray-100 text-gray-700';
  %>

  <div class="template-card card flex flex-col overflow-hidden hover:shadow-md transition-shadow"
       data-category="<%= template.category %>"
       data-name="<%= template.name ? template.name.toLowerCase() : '' %>">

    <!-- Card header -->
    <div class="p-5 border-b border-gray-50">
      <div class="flex items-start justify-between mb-3">
        <!-- Icon -->
        <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <!-- Category badge -->
        <span class="text-xs font-semibold px-2.5 py-1 rounded-full <%= catClass %>">
          <%= template.category %>
        </span>
      </div>

      <h3 class="text-base font-bold text-gray-900 mb-1"><%= template.name %></h3>
      <p class="text-sm text-gray-600 leading-snug line-clamp-2">
        <%= template.description || 'No description available.' %>
      </p>
    </div>

    <!-- Card meta -->
    <div class="px-5 py-3 bg-gray-50 flex items-center justify-between text-xs text-gray-500">
      <div class="flex items-center space-x-1.5">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
        <span>Trigger: <strong><%= triggerLabels[template.triggerType] || template.triggerType || 'Custom' %></strong></span>
      </div>
      <% if (template.stepCount) { %>
      <div class="flex items-center space-x-1.5">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"/>
        </svg>
        <span><%= template.stepCount %> step<%= template.stepCount !== 1 ? 's' : '' %></span>
      </div>
      <% } %>
    </div>

    <!-- Use template CTA -->
    <div class="p-5 mt-auto border-t border-gray-100">
      <form method="POST" action="/dashboard/automations/templates/<%= template._id %>">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <button type="submit"
                class="w-full btn-primary text-sm flex items-center justify-center space-x-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          <span>Use Template</span>
        </button>
      </form>
      <% if (template.previewUrl) { %>
      <a href="<%= template.previewUrl %>" target="_blank"
         class="mt-2 block text-center text-xs text-blue-600 hover:text-blue-700 font-medium">
        Preview automation
      </a>
      <% } %>
    </div>
  </div>
  <% }) %>

</div>

<% } %>

<!-- Search / filter JS -->
<script>
(function () {
  const searchInput    = document.getElementById('template-search');
  const filterBtns     = document.querySelectorAll('.filter-btn');
  const cards          = document.querySelectorAll('.template-card');

  let activeCategory = 'all';

  function applyFilters() {
    const query = searchInput ? searchInput.value.toLowerCase().trim() : '';
    cards.forEach(function (card) {
      const name     = (card.dataset.name || '').toLowerCase();
      const cat      = card.dataset.category || '';
      const matchCat = activeCategory === 'all' || cat === activeCategory;
      const matchQ   = !query || name.includes(query);
      card.style.display = matchCat && matchQ ? '' : 'none';
    });
  }

  filterBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      filterBtns.forEach(function (b) {
        b.classList.remove('active', 'bg-blue-600', 'text-white');
        b.classList.add('bg-gray-100', 'text-gray-700');
      });
      btn.classList.add('active', 'bg-blue-600', 'text-white');
      btn.classList.remove('bg-gray-100', 'text-gray-700');
      activeCategory = btn.dataset.category;
      applyFilters();
    });
  });

  if (searchInput) {
    searchInput.addEventListener('input', applyFilters);
  }
})();
</script>
