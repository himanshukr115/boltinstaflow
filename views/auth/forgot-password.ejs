<%- contentFor('body') %>
<div class="w-full max-w-md mx-auto">
  <!-- Back link -->
  <a href="/auth/login" class="inline-flex items-center space-x-1.5 text-sm text-gray-500 hover:text-gray-700 mb-8 transition-colors">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
    </svg>
    <span>Back to sign in</span>
  </a>

  <!-- Icon -->
  <div class="w-14 h-14 bg-blue-100 rounded-2xl flex items-center justify-center mb-6">
    <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
    </svg>
  </div>

  <!-- Heading -->
  <div class="mb-8">
    <h2 class="text-3xl font-bold text-gray-900">Forgot your password?</h2>
    <p class="mt-2 text-gray-500">No worries — enter your email and we'll send you reset instructions.</p>
  </div>

  <% if (typeof emailSent !== 'undefined' && emailSent) { %>
    <!-- Success state -->
    <div class="p-5 bg-green-50 border border-green-200 rounded-xl mb-6">
      <div class="flex items-start space-x-3">
        <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div>
          <p class="text-sm font-semibold text-green-800">Check your email</p>
          <p class="text-sm text-green-700 mt-0.5">
            We sent a reset link to <strong><%= typeof email !== 'undefined' ? email : 'your email' %></strong>.
            The link expires in 30 minutes.
          </p>
        </div>
      </div>
    </div>
    <p class="text-sm text-gray-500 text-center">
      Didn't receive it?
      <button onclick="document.getElementById('resend-form').submit()" class="text-blue-600 hover:text-blue-700 font-medium">Resend email</button>
    </p>
    <form id="resend-form" action="/auth/forgot-password" method="POST" class="hidden">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <input type="hidden" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>">
    </form>
  <% } else { %>
    <!-- Forgot password form -->
    <form action="/auth/forgot-password" method="POST" class="space-y-5" novalidate>
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

      <div>
        <label for="email" class="form-label">Email address</label>
        <input
          type="email"
          id="email"
          name="email"
          autocomplete="email"
          required
          value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>"
          placeholder="you@example.com"
          class="input-field"
          autofocus
        >
      </div>

      <button type="submit" class="w-full btn-primary py-2.5 text-base">
        Send reset instructions
      </button>
    </form>
  <% } %>

  <!-- Sign in link -->
  <p class="text-center text-sm text-gray-500 mt-8">
    Remember your password?
    <a href="/auth/login" class="text-blue-600 hover:text-blue-700 font-semibold">Sign in</a>
  </p>
</div>
