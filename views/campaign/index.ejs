<%
  layout = 'layouts/main';
  title = 'Campaigns';
  activePage = 'campaigns';
%>

<!-- Page Header -->
<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Campaigns</h1>
    <p class="text-gray-500 mt-1">Send bulk DMs to your Instagram audience</p>
  </div>
  <a href="/campaigns/create" class="btn-primary flex items-center space-x-2">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    <span>New Campaign</span>
  </a>
</div>

<!-- Stats Bar -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
    <p class="text-2xl font-bold text-gray-900"><%= typeof campaignStats !== 'undefined' ? campaignStats.total : '12' %></p>
    <p class="text-sm text-gray-500 mt-0.5">Total Campaigns</p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
    <p class="text-2xl font-bold text-green-600"><%= typeof campaignStats !== 'undefined' ? campaignStats.running : '3' %></p>
    <p class="text-sm text-gray-500 mt-0.5">Running Now</p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
    <p class="text-2xl font-bold text-blue-600"><%= typeof campaignStats !== 'undefined' ? campaignStats.totalSent.toLocaleString() : '48,290' %></p>
    <p class="text-sm text-gray-500 mt-0.5">Total DMs Sent</p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
    <p class="text-2xl font-bold text-gray-900"><%= typeof campaignStats !== 'undefined' ? campaignStats.avgOpenRate + '%' : '34%' %></p>
    <p class="text-sm text-gray-500 mt-0.5">Avg. Open Rate</p>
  </div>
</div>

<% const campaigns = typeof campaigns !== 'undefined' ? campaigns : [
  { _id: '1', name: 'Summer Sale 2025', igAccount: '@my_brand', status: 'completed', audienceSize: 1240, sent: 1238, scheduled: null, createdAt: new Date(Date.now() - 3*24*60*60*1000) },
  { _id: '2', name: 'Product Launch DM', igAccount: '@my_brand', status: 'running', audienceSize: 850, sent: 620, scheduled: null, createdAt: new Date(Date.now() - 1*24*60*60*1000) },
  { _id: '3', name: 'Black Friday Promo', igAccount: '@my_brand', status: 'scheduled', audienceSize: 3400, sent: 0, scheduled: new Date(Date.now() + 5*24*60*60*1000), createdAt: new Date(Date.now() - 2*60*60*1000) },
  { _id: '4', name: 'Webinar Invite', igAccount: '@my_brand', status: 'draft', audienceSize: 500, sent: 0, scheduled: null, createdAt: new Date(Date.now() - 60*60*1000) },
  { _id: '5', name: 'Flash Sale Alert', igAccount: '@my_brand', status: 'paused', audienceSize: 700, sent: 340, scheduled: null, createdAt: new Date(Date.now() - 5*24*60*60*1000) },
]; %>

<% if (campaigns.length > 0) { %>
  <div class="card p-0 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="border-b border-gray-100 bg-gray-50">
            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-6 py-3.5">Campaign</th>
            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-6 py-3.5">Status</th>
            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-6 py-3.5 hidden md:table-cell">Progress</th>
            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-6 py-3.5 hidden lg:table-cell">Scheduled</th>
            <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wide px-6 py-3.5">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% campaigns.forEach(function(campaign) { %>
            <tr class="hover:bg-gray-50 transition-colors">
              <!-- Name -->
              <td class="px-6 py-4">
                <div class="flex items-center space-x-3">
                  <div class="w-9 h-9 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-gray-900"><%= campaign.name %></p>
                    <p class="text-xs text-gray-400"><%= campaign.igAccount %> &middot; <%= campaign.audienceSize.toLocaleString() %> contacts</p>
                  </div>
                </div>
              </td>

              <!-- Status -->
              <td class="px-6 py-4">
                <% if (campaign.status === 'running') { %>
                  <span class="badge-active flex items-center space-x-1 w-fit">
                    <div class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></div>
                    <span>Running</span>
                  </span>
                <% } else if (campaign.status === 'completed') { %>
                  <span class="inline-flex items-center space-x-1 bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded-full">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    <span>Completed</span>
                  </span>
                <% } else if (campaign.status === 'scheduled') { %>
                  <span class="badge-warning">Scheduled</span>
                <% } else if (campaign.status === 'paused') { %>
                  <span class="badge-warning">Paused</span>
                <% } else { %>
                  <span class="badge-inactive">Draft</span>
                <% } %>
              </td>

              <!-- Progress -->
              <td class="px-6 py-4 hidden md:table-cell">
                <% const progress = campaign.audienceSize > 0 ? Math.round((campaign.sent / campaign.audienceSize) * 100) : 0; %>
                <div class="w-32">
                  <div class="flex justify-between text-xs text-gray-500 mb-1">
                    <span><%= campaign.sent.toLocaleString() %> sent</span>
                    <span><%= progress %>%</span>
                  </div>
                  <div class="w-full bg-gray-200 rounded-full h-1.5">
                    <div class="bg-blue-600 h-1.5 rounded-full" style="width: <%= progress %>%"></div>
                  </div>
                </div>
              </td>

              <!-- Scheduled -->
              <td class="px-6 py-4 hidden lg:table-cell text-sm text-gray-600">
                <% if (campaign.scheduled) { %>
                  <%= new Date(campaign.scheduled).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                <% } else { %>
                  <span class="text-gray-400">—</span>
                <% } %>
              </td>

              <!-- Actions -->
              <td class="px-6 py-4">
                <div class="flex items-center justify-end space-x-1">
                  <% if (campaign.status === 'draft' || campaign.status === 'scheduled') { %>
                    <a href="/campaigns/<%= campaign._id %>/edit" class="p-1.5 rounded-lg text-gray-400 hover:text-gray-700 hover:bg-gray-100 transition-colors" title="Edit">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                      </svg>
                    </a>
                  <% } %>

                  <% if (campaign.status === 'running') { %>
                    <form action="/campaigns/<%= campaign._id %>/pause" method="POST" class="inline">
                      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                      <button type="submit" class="p-1.5 rounded-lg text-gray-400 hover:text-yellow-600 hover:bg-yellow-50 transition-colors" title="Pause">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                      </button>
                    </form>
                  <% } else if (campaign.status === 'paused') { %>
                    <form action="/campaigns/<%= campaign._id %>/resume" method="POST" class="inline">
                      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                      <button type="submit" class="p-1.5 rounded-lg text-gray-400 hover:text-green-600 hover:bg-green-50 transition-colors" title="Resume">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                      </button>
                    </form>
                  <% } %>

                  <a href="/campaigns/<%= campaign._id %>/analytics" class="p-1.5 rounded-lg text-gray-400 hover:text-blue-600 hover:bg-blue-50 transition-colors" title="Analytics">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                  </a>

                  <button
                    type="button"
                    onclick="window.confirmModal('Delete Campaign', 'Delete &quot;<%= campaign.name %>&quot;?', function() { document.getElementById('del-camp-<%= campaign._id %>').submit(); })"
                    class="p-1.5 rounded-lg text-gray-400 hover:text-red-600 hover:bg-red-50 transition-colors"
                    title="Delete"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                  </button>
                  <form id="del-camp-<%= campaign._id %>" action="/campaigns/<%= campaign._id %>" method="POST" class="hidden">
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                    <input type="hidden" name="_method" value="DELETE">
                  </form>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
<% } else { %>
  <div class="card text-center py-16">
    <div class="w-20 h-20 bg-blue-100 rounded-2xl flex items-center justify-center mx-auto mb-5">
      <svg class="w-10 h-10 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
      </svg>
    </div>
    <h3 class="text-lg font-semibold text-gray-900 mb-2">No campaigns yet</h3>
    <p class="text-gray-500 max-w-md mx-auto mb-6">Create a campaign to send bulk DMs to your followers or a specific audience segment.</p>
    <a href="/campaigns/create" class="btn-primary inline-flex items-center space-x-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      <span>Create First Campaign</span>
    </a>
  </div>
<% } %>
