<%
  layout = 'layouts/main';
  title = 'Dashboard';
  activePage = 'dashboard';
%>

<!-- Welcome Header -->
<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">
      Good <%= new Date().getHours() < 12 ? 'morning' : new Date().getHours() < 17 ? 'afternoon' : 'evening' %>,
      <%= typeof user !== 'undefined' ? user.name.split(' ')[0] : 'there' %> 👋
    </h1>
    <p class="text-gray-500 mt-1">Here's what's happening with your Instagram automation today.</p>
  </div>
  <div class="hidden sm:flex items-center space-x-3">
    <a href="/instagram/connect" class="btn-secondary flex items-center space-x-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      <span>Connect Instagram</span>
    </a>
    <a href="/automations/create" class="btn-primary flex items-center space-x-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
      </svg>
      <span>New Automation</span>
    </a>
  </div>
</div>

<!-- Stats Grid -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">

  <!-- Total Contacts -->
  <div class="stat-card">
    <div>
      <p class="text-sm font-medium text-gray-500">Total Contacts</p>
      <p class="text-3xl font-bold text-gray-900 mt-1"><%= typeof stats !== 'undefined' ? stats.totalContacts.toLocaleString() : '1,284' %></p>
      <div class="flex items-center space-x-1 mt-2">
        <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12"/>
        </svg>
        <span class="text-sm text-green-600 font-medium">+12%</span>
        <span class="text-sm text-gray-400">vs last month</span>
      </div>
    </div>
    <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
      <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
      </svg>
    </div>
  </div>

  <!-- DMs Sent Today -->
  <div class="stat-card">
    <div>
      <p class="text-sm font-medium text-gray-500">DMs Sent Today</p>
      <p class="text-3xl font-bold text-gray-900 mt-1"><%= typeof stats !== 'undefined' ? stats.dmsSentToday.toLocaleString() : '247' %></p>
      <div class="flex items-center space-x-1 mt-2">
        <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12"/>
        </svg>
        <span class="text-sm text-green-600 font-medium">+34%</span>
        <span class="text-sm text-gray-400">vs yesterday</span>
      </div>
    </div>
    <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center flex-shrink-0">
      <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
      </svg>
    </div>
  </div>

  <!-- Active Automations -->
  <div class="stat-card">
    <div>
      <p class="text-sm font-medium text-gray-500">Active Automations</p>
      <p class="text-3xl font-bold text-gray-900 mt-1"><%= typeof stats !== 'undefined' ? stats.activeAutomations : '8' %></p>
      <div class="flex items-center space-x-1 mt-2">
        <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
        <span class="text-sm text-gray-500">Running right now</span>
      </div>
    </div>
    <div class="w-12 h-12 bg-yellow-100 rounded-xl flex items-center justify-center flex-shrink-0">
      <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
      </svg>
    </div>
  </div>

  <!-- Campaigns Running -->
  <div class="stat-card">
    <div>
      <p class="text-sm font-medium text-gray-500">Campaigns Running</p>
      <p class="text-3xl font-bold text-gray-900 mt-1"><%= typeof stats !== 'undefined' ? stats.campaignsRunning : '3' %></p>
      <div class="flex items-center space-x-1 mt-2">
        <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 13l-5 5m0 0l-5-5m5 5V6"/>
        </svg>
        <span class="text-sm text-red-600 font-medium">-1</span>
        <span class="text-sm text-gray-400">vs last week</span>
      </div>
    </div>
    <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center flex-shrink-0">
      <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
      </svg>
    </div>
  </div>
</div>

<!-- Main Content Grid -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">

  <!-- DM Activity Chart (2/3 width) -->
  <div class="lg:col-span-2 card">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="text-base font-semibold text-gray-900">DM Activity</h2>
        <p class="text-sm text-gray-500">Messages sent over the last 7 days</p>
      </div>
      <select class="text-sm border border-gray-300 rounded-lg px-3 py-1.5 text-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500">
        <option>Last 7 days</option>
        <option>Last 30 days</option>
        <option>Last 90 days</option>
      </select>
    </div>
    <!-- Chart.js placeholder -->
    <div class="relative h-56 flex items-center justify-center bg-gray-50 rounded-lg">
      <canvas id="dmActivityChart" class="w-full h-full"></canvas>
    </div>
  </div>

  <!-- Plan Usage (1/3 width) -->
  <div class="card">
    <div class="flex items-center justify-between mb-5">
      <h2 class="text-base font-semibold text-gray-900">Plan Usage</h2>
      <a href="/subscription" class="text-xs text-blue-600 hover:text-blue-700 font-medium">Upgrade</a>
    </div>

    <div class="space-y-5">
      <!-- DMs Used -->
      <div>
        <div class="flex justify-between items-center mb-1.5">
          <span class="text-sm font-medium text-gray-700">DMs Sent</span>
          <span class="text-sm text-gray-500">
            <span class="font-semibold text-gray-900"><%= typeof usage !== 'undefined' ? usage.dmsUsed.toLocaleString() : '4,280' %></span>
            / <%= typeof usage !== 'undefined' ? usage.dmsLimit.toLocaleString() : '5,000' %>
          </span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-2">
          <div class="bg-blue-600 h-2 rounded-full transition-all duration-500" style="width: <%= typeof usage !== 'undefined' ? Math.round((usage.dmsUsed / usage.dmsLimit) * 100) : 86 %>%"></div>
        </div>
        <p class="text-xs text-gray-400 mt-1"><%= typeof usage !== 'undefined' ? Math.round((usage.dmsUsed / usage.dmsLimit) * 100) : 86 %>% used</p>
      </div>

      <!-- Contacts -->
      <div>
        <div class="flex justify-between items-center mb-1.5">
          <span class="text-sm font-medium text-gray-700">Contacts</span>
          <span class="text-sm text-gray-500">
            <span class="font-semibold text-gray-900"><%= typeof usage !== 'undefined' ? usage.contactsUsed.toLocaleString() : '1,284' %></span>
            / <%= typeof usage !== 'undefined' ? usage.contactsLimit.toLocaleString() : '5,000' %>
          </span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-2">
          <div class="bg-green-500 h-2 rounded-full transition-all duration-500" style="width: <%= typeof usage !== 'undefined' ? Math.round((usage.contactsUsed / usage.contactsLimit) * 100) : 26 %>%"></div>
        </div>
        <p class="text-xs text-gray-400 mt-1"><%= typeof usage !== 'undefined' ? Math.round((usage.contactsUsed / usage.contactsLimit) * 100) : 26 %>% used</p>
      </div>

      <!-- Automations -->
      <div>
        <div class="flex justify-between items-center mb-1.5">
          <span class="text-sm font-medium text-gray-700">Automations</span>
          <span class="text-sm text-gray-500">
            <span class="font-semibold text-gray-900">8</span> / 10
          </span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-2">
          <div class="bg-yellow-500 h-2 rounded-full transition-all duration-500" style="width: 80%"></div>
        </div>
        <p class="text-xs text-gray-400 mt-1">80% used</p>
      </div>

      <!-- Plan info -->
      <div class="pt-3 border-t border-gray-100">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-700">
              <%= typeof user !== 'undefined' && user.subscription ? user.subscription.planName : 'Starter Plan' %>
            </p>
            <p class="text-xs text-gray-400">Resets in 8 days</p>
          </div>
          <a href="/subscription/pricing" class="btn-primary text-xs py-1.5 px-3">Upgrade</a>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Quick Actions + Activity + IG Accounts -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <!-- Quick Actions -->
  <div class="card">
    <h2 class="text-base font-semibold text-gray-900 mb-4">Quick Actions</h2>
    <div class="space-y-2">
      <a href="/instagram/connect" class="flex items-center space-x-3 p-3 rounded-lg hover:bg-blue-50 transition-colors group">
        <div class="w-9 h-9 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-blue-200 transition-colors">
          <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-900">Connect Instagram</p>
          <p class="text-xs text-gray-500">Add a new account</p>
        </div>
      </a>
      <a href="/automations/create" class="flex items-center space-x-3 p-3 rounded-lg hover:bg-green-50 transition-colors group">
        <div class="w-9 h-9 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-green-200 transition-colors">
          <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-900">Create Automation</p>
          <p class="text-xs text-gray-500">Set up keyword triggers</p>
        </div>
      </a>
      <a href="/campaigns/create" class="flex items-center space-x-3 p-3 rounded-lg hover:bg-yellow-50 transition-colors group">
        <div class="w-9 h-9 bg-yellow-100 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-yellow-200 transition-colors">
          <svg class="w-4 h-4 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-900">New Campaign</p>
          <p class="text-xs text-gray-500">Send bulk DMs</p>
        </div>
      </a>
      <a href="/analytics" class="flex items-center space-x-3 p-3 rounded-lg hover:bg-purple-50 transition-colors group">
        <div class="w-9 h-9 bg-purple-100 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-purple-200 transition-colors">
          <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-900">View Analytics</p>
          <p class="text-xs text-gray-500">Performance insights</p>
        </div>
      </a>
    </div>
  </div>

  <!-- Recent Activity Feed -->
  <div class="card">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-base font-semibold text-gray-900">Recent Activity</h2>
      <a href="/activity" class="text-xs text-blue-600 hover:text-blue-700 font-medium">View all</a>
    </div>
    <div class="space-y-4">
      <% const activities = typeof recentActivity !== 'undefined' ? recentActivity : [
        { type: 'dm_sent', message: 'DM sent to @sarah_designs', time: '2 min ago', color: 'blue' },
        { type: 'trigger', message: 'Keyword "price" triggered automation', time: '8 min ago', color: 'green' },
        { type: 'contact', message: 'New contact @mark_photo added', time: '15 min ago', color: 'yellow' },
        { type: 'campaign', message: 'Campaign "Summer Sale" completed', time: '1 hr ago', color: 'purple' },
        { type: 'dm_sent', message: 'DM sent to @tech_guru99', time: '2 hrs ago', color: 'blue' },
      ]; %>
      <% activities.forEach(function(activity) { %>
        <div class="flex items-start space-x-3">
          <div class="w-8 h-8 rounded-full bg-<%= activity.color %>-100 flex items-center justify-center flex-shrink-0 mt-0.5">
            <% if (activity.type === 'dm_sent') { %>
              <svg class="w-3.5 h-3.5 text-<%= activity.color %>-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
            <% } else if (activity.type === 'trigger') { %>
              <svg class="w-3.5 h-3.5 text-<%= activity.color %>-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            <% } else { %>
              <svg class="w-3.5 h-3.5 text-<%= activity.color %>-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
              </svg>
            <% } %>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm text-gray-800"><%= activity.message %></p>
            <p class="text-xs text-gray-400 mt-0.5"><%= activity.time %></p>
          </div>
        </div>
      <% }); %>
    </div>
  </div>

  <!-- Connected Instagram Accounts -->
  <div class="card">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-base font-semibold text-gray-900">Instagram Accounts</h2>
      <a href="/instagram" class="text-xs text-blue-600 hover:text-blue-700 font-medium">Manage</a>
    </div>

    <% if (typeof igAccounts !== 'undefined' && igAccounts.length > 0) { %>
      <div class="space-y-3">
        <% igAccounts.forEach(function(account) { %>
          <div class="flex items-center space-x-3 p-3 bg-gray-50 rounded-lg">
            <img src="<%= account.profilePic || '/images/default-avatar.png' %>" alt="<%= account.username %>" class="w-10 h-10 rounded-full object-cover">
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-gray-900 truncate">@<%= account.username %></p>
              <p class="text-xs text-gray-500"><%= account.followerCount ? account.followerCount.toLocaleString() + ' followers' : 'Connected' %></p>
            </div>
            <span class="badge-active flex-shrink-0">Active</span>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <!-- No accounts connected -->
      <div class="text-center py-6">
        <div class="w-12 h-12 bg-gray-100 rounded-xl flex items-center justify-center mx-auto mb-3">
          <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
        </div>
        <p class="text-sm font-medium text-gray-700">No accounts connected</p>
        <p class="text-xs text-gray-400 mt-1 mb-3">Connect your Instagram to get started</p>
        <a href="/instagram/connect" class="btn-primary text-sm py-1.5 px-4">Connect Instagram</a>
      </div>
    <% } %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  // DM Activity Chart
  const ctx = document.getElementById('dmActivityChart');
  if (ctx) {
    const dmChart = new Chart(ctx, {
      type: 'line',
      data: {
        labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
        datasets: [{
          label: 'DMs Sent',
          data: [185, 220, 195, 260, 240, 180, 247],
          borderColor: '#2563eb',
          backgroundColor: 'rgba(37, 99, 235, 0.08)',
          borderWidth: 2.5,
          tension: 0.4,
          fill: true,
          pointBackgroundColor: '#2563eb',
          pointRadius: 4,
          pointHoverRadius: 6
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#1e293b',
            padding: 10,
            cornerRadius: 8,
            callbacks: {
              label: function(context) {
                return ' ' + context.parsed.y + ' DMs';
              }
            }
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            grid: { color: 'rgba(0,0,0,0.05)' },
            ticks: { color: '#94a3b8', font: { size: 12 } }
          },
          x: {
            grid: { display: false },
            ticks: { color: '#94a3b8', font: { size: 12 } }
          }
        }
      }
    });
  }
</script>
