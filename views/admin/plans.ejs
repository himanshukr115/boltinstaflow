<%
  layout = 'layouts/admin';
  title = 'Plan Management';
  adminActivePage = 'plans';
%>

<div class="flex items-center justify-between mb-6">
  <div>
    <p class="text-sm text-gray-500">Manage subscription plans and pricing</p>
  </div>
  <button type="button" onclick="openPlanModal()" class="btn-primary flex items-center space-x-2">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    <span>Create Plan</span>
  </button>
</div>

<!-- Drag-to-reorder hint -->
<div class="mb-4 flex items-center space-x-2 text-sm text-gray-400">
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
  </svg>
  <span>Drag rows to reorder how plans appear on the pricing page</span>
</div>

<!-- Plans Table -->
<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="border-b border-gray-100 bg-gray-50">
          <th class="w-8 px-4 py-3"></th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Plan</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden sm:table-cell">Price (Monthly)</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden md:table-cell">Price (Yearly)</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Status</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden lg:table-cell">Subscribers</th>
          <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wide px-6 py-3">Actions</th>
        </tr>
      </thead>
      <tbody id="plans-table" class="divide-y divide-gray-50">

        <% const plans = typeof plans !== 'undefined' ? plans : [
          { _id: 'starter', name: 'Starter', priceMonthly: 999, priceYearly: 799, currency: '₹', isActive: true, isPopular: false, subscriberCount: 428 },
          { _id: 'growth', name: 'Growth', priceMonthly: 2499, priceYearly: 1999, currency: '₹', isActive: true, isPopular: true, subscriberCount: 1024 },
          { _id: 'pro', name: 'Pro', priceMonthly: 4999, priceYearly: 3999, currency: '₹', isActive: true, isPopular: false, subscriberCount: 395 },
        ]; %>

        <% plans.forEach(function(plan) { %>
          <tr class="hover:bg-gray-50 transition-colors plan-row" data-id="<%= plan._id %>">
            <td class="px-4 py-4 w-8 cursor-grab text-gray-300 hover:text-gray-500">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/>
              </svg>
            </td>
            <td class="px-4 py-4">
              <div class="flex items-center space-x-3">
                <div class="w-9 h-9 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
                  <span class="text-sm font-bold text-blue-600"><%= plan.name.charAt(0) %></span>
                </div>
                <div>
                  <div class="flex items-center space-x-2">
                    <p class="text-sm font-semibold text-gray-900"><%= plan.name %></p>
                    <% if (plan.isPopular) { %>
                      <span class="bg-blue-100 text-blue-700 text-xs font-bold px-2 py-0.5 rounded-full">POPULAR</span>
                    <% } %>
                  </div>
                  <p class="text-xs text-gray-500">ID: <%= plan._id %></p>
                </div>
              </div>
            </td>
            <td class="px-4 py-4 hidden sm:table-cell text-sm font-medium text-gray-900">
              <%= plan.currency %><%= plan.priceMonthly.toLocaleString() %>/mo
            </td>
            <td class="px-4 py-4 hidden md:table-cell text-sm font-medium text-gray-900">
              <%= plan.currency %><%= plan.priceYearly.toLocaleString() %>/mo
            </td>
            <td class="px-4 py-4">
              <% if (plan.isActive) { %>
                <span class="badge-active">Active</span>
              <% } else { %>
                <span class="badge-inactive">Inactive</span>
              <% } %>
            </td>
            <td class="px-4 py-4 hidden lg:table-cell text-sm text-gray-700 font-medium">
              <%= plan.subscriberCount.toLocaleString() %>
            </td>
            <td class="px-6 py-4">
              <div class="flex items-center justify-end space-x-1">
                <button
                  type="button"
                  onclick="openPlanModal('<%= plan._id %>')"
                  class="p-1.5 rounded-lg text-gray-400 hover:text-blue-600 hover:bg-blue-50 transition-colors"
                  title="Edit"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                  </svg>
                </button>
                <form action="/admin/plans/<%= plan._id %>/toggle" method="POST" class="inline">
                  <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                  <button type="submit" class="p-1.5 rounded-lg text-gray-400 hover:<%= plan.isActive ? 'text-yellow-600 hover:bg-yellow-50' : 'text-green-600 hover:bg-green-50' %> transition-colors" title="<%= plan.isActive ? 'Deactivate' : 'Activate' %>">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <% if (plan.isActive) { %>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      <% } else { %>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                      <% } %>
                    </svg>
                  </button>
                </form>
                <% if (plan.subscriberCount === 0) { %>
                  <button
                    type="button"
                    onclick="window.confirmModal('Delete Plan', 'Delete the <%= plan.name %> plan?', function() { document.getElementById('del-plan-<%= plan._id %>').submit(); })"
                    class="p-1.5 rounded-lg text-gray-400 hover:text-red-600 hover:bg-red-50 transition-colors"
                    title="Delete"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                  </button>
                  <form id="del-plan-<%= plan._id %>" action="/admin/plans/<%= plan._id %>" method="POST" class="hidden">
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                    <input type="hidden" name="_method" value="DELETE">
                  </form>
                <% } %>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<!-- Create/Edit Plan Modal -->
<div id="plan-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black bg-opacity-50" onclick="closePlanModal()"></div>
  <div class="relative bg-white rounded-xl shadow-xl max-w-lg w-full">
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
      <h3 class="text-lg font-semibold text-gray-900" id="modal-title">Create Plan</h3>
      <button onclick="closePlanModal()" class="text-gray-400 hover:text-gray-600 p-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <form action="/admin/plans" method="POST" id="plan-modal-form" class="p-6 space-y-4">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <input type="hidden" name="_method" id="plan-form-method" value="POST">
      <input type="hidden" name="planId" id="plan-form-id" value="">

      <div class="grid grid-cols-2 gap-4">
        <div class="col-span-2">
          <label class="form-label">Plan name</label>
          <input type="text" name="name" id="plan-form-name" class="input-field" required placeholder="e.g. Growth">
        </div>
        <div>
          <label class="form-label">Monthly price</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm">₹</span>
            <input type="number" name="priceMonthly" id="plan-form-monthly" class="input-field pl-7" required min="0" placeholder="2499">
          </div>
        </div>
        <div>
          <label class="form-label">Yearly price/mo</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm">₹</span>
            <input type="number" name="priceYearly" id="plan-form-yearly" class="input-field pl-7" required min="0" placeholder="1999">
          </div>
        </div>
        <div>
          <label class="form-label">DMs/month limit</label>
          <input type="number" name="dmsLimit" id="plan-form-dms" class="input-field" required min="0" placeholder="10000">
        </div>
        <div>
          <label class="form-label">Contacts limit</label>
          <input type="number" name="contactsLimit" id="plan-form-contacts" class="input-field" required min="0" placeholder="10000">
        </div>
        <div>
          <label class="form-label">Max IG accounts</label>
          <input type="number" name="igAccountsLimit" id="plan-form-ig" class="input-field" required min="1" placeholder="3">
        </div>
        <div>
          <label class="form-label">Automations limit</label>
          <input type="number" name="automationsLimit" id="plan-form-auto" class="input-field" placeholder="-1 for unlimited" value="-1">
        </div>
      </div>

      <div>
        <label class="form-label">Features (one per line)</label>
        <textarea name="features" id="plan-form-features" rows="5" class="input-field resize-none" placeholder="10,000 DMs/month&#10;3 Instagram accounts&#10;Unlimited automations"></textarea>
      </div>

      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-4">
          <label class="flex items-center space-x-2 cursor-pointer">
            <input type="checkbox" name="isActive" id="plan-form-active" class="w-4 h-4 text-blue-600 rounded" checked>
            <span class="text-sm font-medium text-gray-700">Active</span>
          </label>
          <label class="flex items-center space-x-2 cursor-pointer">
            <input type="checkbox" name="isPopular" id="plan-form-popular" class="w-4 h-4 text-blue-600 rounded">
            <span class="text-sm font-medium text-gray-700">Mark as Popular</span>
          </label>
        </div>
      </div>

      <div class="flex space-x-3 pt-2">
        <button type="button" onclick="closePlanModal()" class="flex-1 btn-secondary">Cancel</button>
        <button type="submit" class="flex-1 btn-primary" id="plan-form-submit">Create Plan</button>
      </div>
    </form>
  </div>
</div>

<script>
  function openPlanModal(planId) {
    const modal = document.getElementById('plan-modal');
    const title = document.getElementById('modal-title');
    const submitBtn = document.getElementById('plan-form-submit');
    const methodInput = document.getElementById('plan-form-method');
    const idInput = document.getElementById('plan-form-id');

    if (planId) {
      title.textContent = 'Edit Plan';
      submitBtn.textContent = 'Save Changes';
      methodInput.value = 'PATCH';
      idInput.value = planId;
      document.getElementById('plan-modal-form').action = '/admin/plans/' + planId;
      // Could pre-fill form fields here from server data
    } else {
      title.textContent = 'Create Plan';
      submitBtn.textContent = 'Create Plan';
      methodInput.value = 'POST';
      idInput.value = '';
      document.getElementById('plan-modal-form').action = '/admin/plans';
      document.getElementById('plan-modal-form').reset();
    }

    modal.classList.remove('hidden');
  }

  function closePlanModal() {
    document.getElementById('plan-modal').classList.add('hidden');
  }
</script>
