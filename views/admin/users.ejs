<%
  layout = 'layouts/admin';
  title = 'User Management';
  adminActivePage = 'users';
%>

<div class="flex flex-col sm:flex-row gap-3 mb-6">
  <div class="relative flex-1">
    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
    </svg>
    <input type="text" placeholder="Search by name, email..." class="input-field pl-9" id="user-search">
  </div>
  <select class="input-field sm:w-36" id="plan-filter">
    <option value="">All plans</option>
    <option value="starter">Starter</option>
    <option value="growth">Growth</option>
    <option value="pro">Pro</option>
    <option value="none">No plan</option>
  </select>
  <select class="input-field sm:w-36" id="status-filter">
    <option value="">All statuses</option>
    <option value="active">Active</option>
    <option value="suspended">Suspended</option>
    <option value="banned">Banned</option>
  </select>
</div>

<!-- Summary Stats -->
<div class="grid grid-cols-3 gap-4 mb-6">
  <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
    <p class="text-2xl font-bold text-gray-900"><%= typeof userStats !== 'undefined' ? userStats.total.toLocaleString() : '2,484' %></p>
    <p class="text-xs text-gray-500 mt-0.5">Total Users</p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
    <p class="text-2xl font-bold text-blue-600"><%= typeof userStats !== 'undefined' ? userStats.paying.toLocaleString() : '1,847' %></p>
    <p class="text-xs text-gray-500 mt-0.5">Paying</p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
    <p class="text-2xl font-bold text-gray-500"><%= typeof userStats !== 'undefined' ? userStats.free.toLocaleString() : '637' %></p>
    <p class="text-xs text-gray-500 mt-0.5">Free Tier</p>
  </div>
</div>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="border-b border-gray-100 bg-gray-50">
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-6 py-3.5">User</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3.5 hidden sm:table-cell">Plan</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3.5 hidden md:table-cell">IG Accounts</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3.5">Status</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3.5 hidden lg:table-cell">Joined</th>
          <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wide px-6 py-3.5">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50" id="users-table-body">

        <% const users = typeof users !== 'undefined' ? users : [
          { _id: 'u1', name: 'Sarah Johnson', email: 'sarah@example.com', plan: 'Growth', igAccountsCount: 2, status: 'active', isAdmin: false, joinedAt: new Date(Date.now() - 10*24*60*60*1000) },
          { _id: 'u2', name: 'Mike Chen', email: 'mike@techcorp.com', plan: 'Starter', igAccountsCount: 1, status: 'active', isAdmin: false, joinedAt: new Date(Date.now() - 20*24*60*60*1000) },
          { _id: 'u3', name: 'Emma Wilson', email: 'emma@brand.co', plan: 'Pro', igAccountsCount: 3, status: 'active', isAdmin: false, joinedAt: new Date(Date.now() - 5*24*60*60*1000) },
          { _id: 'u4', name: 'James Kumar', email: 'james@startup.in', plan: null, igAccountsCount: 0, status: 'suspended', isAdmin: false, joinedAt: new Date(Date.now() - 45*24*60*60*1000) },
          { _id: 'u5', name: 'Admin User', email: 'admin@instaflow.app', plan: null, igAccountsCount: 0, status: 'active', isAdmin: true, joinedAt: new Date(Date.now() - 90*24*60*60*1000) },
        ]; %>

        <% users.forEach(function(u) { %>
          <tr class="hover:bg-gray-50 transition-colors user-row" data-status="<%= u.status %>" data-plan="<%= u.plan ? u.plan.toLowerCase() : 'none' %>">
            <td class="px-6 py-4">
              <div class="flex items-center space-x-3">
                <div class="w-9 h-9 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center text-white text-sm font-bold flex-shrink-0">
                  <%= u.name.charAt(0) %>
                </div>
                <div>
                  <div class="flex items-center space-x-2">
                    <p class="text-sm font-semibold text-gray-900"><%= u.name %></p>
                    <% if (u.isAdmin) { %>
                      <span class="bg-red-100 text-red-700 text-xs font-bold px-1.5 py-0.5 rounded">ADMIN</span>
                    <% } %>
                  </div>
                  <p class="text-xs text-gray-500"><%= u.email %></p>
                </div>
              </div>
            </td>
            <td class="px-4 py-4 hidden sm:table-cell">
              <% if (u.plan) { %>
                <span class="text-sm font-medium text-gray-900"><%= u.plan %></span>
              <% } else { %>
                <span class="text-sm text-gray-400">Free</span>
              <% } %>
            </td>
            <td class="px-4 py-4 hidden md:table-cell text-sm text-gray-600">
              <%= u.igAccountsCount %> account<%= u.igAccountsCount !== 1 ? 's' : '' %>
            </td>
            <td class="px-4 py-4">
              <% if (u.status === 'active') { %>
                <span class="badge-active">Active</span>
              <% } else if (u.status === 'suspended') { %>
                <span class="badge-warning">Suspended</span>
              <% } else { %>
                <span class="badge-danger">Banned</span>
              <% } %>
            </td>
            <td class="px-4 py-4 hidden lg:table-cell text-sm text-gray-600">
              <%= new Date(u.joinedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
            </td>
            <td class="px-6 py-4">
              <div class="flex items-center justify-end space-x-1">
                <a href="/admin/users/<%= u._id %>" class="p-1.5 rounded-lg text-gray-400 hover:text-blue-600 hover:bg-blue-50 transition-colors" title="View">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                  </svg>
                </a>

                <% if (!u.isAdmin) { %>
                  <% if (u.status === 'active') { %>
                    <form action="/admin/users/<%= u._id %>/suspend" method="POST" class="inline">
                      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                      <button type="submit" class="p-1.5 rounded-lg text-gray-400 hover:text-yellow-600 hover:bg-yellow-50 transition-colors" title="Suspend">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
                        </svg>
                      </button>
                    </form>
                  <% } else { %>
                    <form action="/admin/users/<%= u._id %>/restore" method="POST" class="inline">
                      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                      <button type="submit" class="p-1.5 rounded-lg text-gray-400 hover:text-green-600 hover:bg-green-50 transition-colors" title="Restore">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                      </button>
                    </form>
                  <% } %>

                  <button
                    type="button"
                    onclick="window.confirmModal('Delete User', 'Permanently delete <%= u.name %>? All their data will be removed.', function() { document.getElementById('del-user-<%= u._id %>').submit(); })"
                    class="p-1.5 rounded-lg text-gray-400 hover:text-red-600 hover:bg-red-50 transition-colors"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                  </button>
                  <form id="del-user-<%= u._id %>" action="/admin/users/<%= u._id %>" method="POST" class="hidden">
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                    <input type="hidden" name="_method" value="DELETE">
                  </form>
                <% } %>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if (typeof pagination !== 'undefined' && pagination.totalPages > 1) { %>
    <div class="border-t border-gray-100 px-6 py-4 flex items-center justify-between">
      <p class="text-sm text-gray-500">
        Showing <%= (pagination.currentPage - 1) * pagination.perPage + 1 %> – <%= Math.min(pagination.currentPage * pagination.perPage, pagination.total) %>
        of <%= pagination.total.toLocaleString() %>
      </p>
      <div class="flex items-center space-x-1">
        <a href="?page=<%= pagination.currentPage - 1 %>" class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-50 <%= pagination.currentPage <= 1 ? 'opacity-50 pointer-events-none' : '' %>">Prev</a>
        <a href="?page=<%= pagination.currentPage + 1 %>" class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-50 <%= pagination.currentPage >= pagination.totalPages ? 'opacity-50 pointer-events-none' : '' %>">Next</a>
      </div>
    </div>
  <% } %>
</div>

<script>
  const searchInput = document.getElementById('user-search');
  const planFilter = document.getElementById('plan-filter');
  const statusFilter = document.getElementById('status-filter');
  const rows = document.querySelectorAll('.user-row');

  function filterUsers() {
    const s = searchInput ? searchInput.value.toLowerCase() : '';
    const p = planFilter ? planFilter.value : '';
    const st = statusFilter ? statusFilter.value : '';

    rows.forEach(row => {
      const nameEl = row.querySelector('p.font-semibold');
      const emailEl = row.querySelector('p.text-xs');
      const name = nameEl ? nameEl.textContent.toLowerCase() : '';
      const email = emailEl ? emailEl.textContent.toLowerCase() : '';
      const status = row.dataset.status || '';
      const plan = row.dataset.plan || '';

      const matchSearch = !s || name.includes(s) || email.includes(s);
      const matchPlan = !p || plan === p;
      const matchStatus = !st || status === st;

      row.style.display = matchSearch && matchPlan && matchStatus ? '' : 'none';
    });
  }

  if (searchInput) searchInput.addEventListener('input', filterUsers);
  if (planFilter) planFilter.addEventListener('change', filterUsers);
  if (statusFilter) statusFilter.addEventListener('change', filterUsers);
</script>
