<%
  layout    = 'layouts/admin';
  title     = 'Audit Logs';
  activePage = 'audit-logs';
%>

<!-- Page header -->
<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Audit Logs</h1>
    <p class="text-gray-500 mt-1">Security and activity log of all significant platform actions.</p>
  </div>
  <a href="/admin/audit-logs?export=csv<%= typeof queryString !== 'undefined' ? '&' + queryString : '' %>"
     class="btn-secondary text-sm flex items-center space-x-2">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
    </svg>
    <span>Export CSV</span>
  </a>
</div>

<!-- Filters card -->
<form method="GET" action="/admin/audit-logs" class="card p-5 mb-6">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">

    <!-- User search -->
    <div>
      <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">User</label>
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input type="text" name="userSearch"
               value="<%= typeof filters !== 'undefined' && filters.userSearch ? filters.userSearch : '' %>"
               placeholder="Name or email…"
               class="w-full pl-9 pr-3 py-2 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
    </div>

    <!-- Action type -->
    <div>
      <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Action Type</label>
      <select name="action"
              class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
        <option value="">All actions</option>
        <%
          const actionGroups = {
            'Auth':         ['user.login', 'user.logout', 'user.login_failed', 'user.register', 'password.changed', 'password.reset', '2fa.enabled', '2fa.disabled'],
            'Account':      ['user.updated', 'user.deleted', 'user.suspended', 'user.restored', 'apiKey.regenerated'],
            'Instagram':    ['instagram.connected', 'instagram.disconnected', 'instagram.synced', 'instagram.token_refreshed'],
            'Automation':   ['automation.created', 'automation.updated', 'automation.deleted', 'automation.activated', 'automation.paused'],
            'Campaign':     ['campaign.created', 'campaign.updated', 'campaign.deleted', 'campaign.launched', 'campaign.paused', 'campaign.completed'],
            'Billing':      ['payment.captured', 'payment.failed', 'payment.refunded', 'subscription.created', 'subscription.canceled', 'plan.assigned'],
            'Admin':        ['admin.login', 'admin.plan_created', 'admin.plan_updated', 'admin.settings_updated'],
            'Link Page':    ['linkPage.created', 'linkPage.updated', 'linkPage.deleted'],
          };
          const currentAction = (typeof filters !== 'undefined' && filters.action) ? filters.action : '';
        %>
        <% Object.entries(actionGroups).forEach(function([group, actions]) { %>
        <optgroup label="<%= group %>">
          <% actions.forEach(function(act) { %>
          <option value="<%= act %>" <%= currentAction === act ? 'selected' : '' %>><%= act %></option>
          <% }) %>
        </optgroup>
        <% }) %>
      </select>
    </div>

    <!-- Date from -->
    <div>
      <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Date From</label>
      <input type="date" name="dateFrom"
             value="<%= typeof filters !== 'undefined' && filters.dateFrom ? filters.dateFrom : '' %>"
             class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
    </div>

    <!-- Date to -->
    <div>
      <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Date To</label>
      <input type="date" name="dateTo"
             value="<%= typeof filters !== 'undefined' && filters.dateTo ? filters.dateTo : '' %>"
             class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
    </div>

    <!-- Severity -->
    <div>
      <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Severity</label>
      <select name="severity"
              class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
        <option value="">All severities</option>
        <option value="info"     <%= (typeof filters !== 'undefined' && filters.severity === 'info')     ? 'selected' : '' %>>Info</option>
        <option value="warning"  <%= (typeof filters !== 'undefined' && filters.severity === 'warning')  ? 'selected' : '' %>>Warning</option>
        <option value="critical" <%= (typeof filters !== 'undefined' && filters.severity === 'critical') ? 'selected' : '' %>>Critical</option>
      </select>
    </div>
  </div>

  <div class="flex items-center justify-between mt-4 pt-4 border-t border-gray-100">
    <div class="flex items-center space-x-3">
      <button type="submit" class="btn-primary text-sm flex items-center space-x-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
        </svg>
        <span>Apply Filters</span>
      </button>
      <a href="/admin/audit-logs" class="btn-secondary text-sm">Reset</a>
    </div>
    <% if (typeof totalCount !== 'undefined') { %>
    <p class="text-sm text-gray-500">
      <span class="font-semibold text-gray-900"><%= totalCount.toLocaleString() %></span> log entries
    </p>
    <% } %>
  </div>
</form>

<!-- Audit log table -->
<% if (!logs || logs.length === 0) { %>
<div class="card text-center py-20">
  <div class="w-12 h-12 bg-gray-100 rounded-xl flex items-center justify-center mx-auto mb-3">
    <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
    </svg>
  </div>
  <h3 class="text-base font-semibold text-gray-900 mb-1">No log entries found</h3>
  <p class="text-sm text-gray-400">Try adjusting your filters.</p>
</div>
<% } else { %>

<div class="card overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-gray-50 border-b border-gray-100 text-left">
          <th class="px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider whitespace-nowrap">Timestamp</th>
          <th class="px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">User</th>
          <th class="px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Action</th>
          <th class="px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Resource</th>
          <th class="px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Description</th>
          <th class="px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider whitespace-nowrap">IP Address</th>
          <th class="px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Severity</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% logs.forEach(function(log) { %>
        <%
          // Severity badge classes
          const severityClass = {
            info:     'bg-blue-50 text-blue-700 border border-blue-200',
            warning:  'bg-yellow-50 text-yellow-700 border border-yellow-200',
            critical: 'bg-red-50 text-red-700 border border-red-200',
          };
          const sc = severityClass[log.severity] || severityClass.info;

          // Row highlight for critical entries
          const rowClass = log.severity === 'critical' ? 'bg-red-50/30' : log.severity === 'warning' ? 'bg-yellow-50/30' : '';
        %>
        <tr class="hover:bg-gray-50 transition-colors <%= rowClass %>">

          <!-- Timestamp -->
          <td class="px-5 py-3 whitespace-nowrap">
            <div class="text-xs font-medium text-gray-700">
              <%= new Date(log.createdAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) %>
            </div>
            <div class="text-xs text-gray-400">
              <%= new Date(log.createdAt).toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit', second:'2-digit' }) %>
            </div>
          </td>

          <!-- User -->
          <td class="px-5 py-3">
            <% if (log.userId || log.userRef) { %>
            <a href="/admin/users/<%= (log.userRef && log.userRef._id) || log.userId %>"
               class="flex items-center space-x-2 group">
              <div class="w-7 h-7 rounded-full bg-gradient-to-br from-blue-400 to-violet-500 flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
                <%= log.userRef && log.userRef.name ? log.userRef.name.charAt(0).toUpperCase() : '?' %>
              </div>
              <div class="min-w-0">
                <p class="text-xs font-medium text-gray-900 group-hover:text-blue-600 truncate max-w-28">
                  <%= log.userRef ? log.userRef.name : 'Unknown' %>
                </p>
                <p class="text-xs text-gray-400 truncate max-w-28"><%= log.userRef ? log.userRef.email : String(log.userId) %></p>
              </div>
            </a>
            <% } else { %>
            <span class="text-xs text-gray-400">System</span>
            <% } %>
          </td>

          <!-- Action -->
          <td class="px-5 py-3">
            <code class="text-xs bg-gray-100 text-gray-700 px-2 py-0.5 rounded font-mono whitespace-nowrap"><%= log.action %></code>
          </td>

          <!-- Resource -->
          <td class="px-5 py-3 text-xs text-gray-600 whitespace-nowrap">
            <% if (log.resourceType) { %>
            <span class="capitalize"><%= log.resourceType %></span>
            <% if (log.resourceId) { %>
            <span class="text-gray-400"> #<%= String(log.resourceId).slice(-6) %></span>
            <% } %>
            <% } else { %>
            <span class="text-gray-400">—</span>
            <% } %>
          </td>

          <!-- Description / meta -->
          <td class="px-5 py-3 max-w-xs">
            <p class="text-xs text-gray-600 leading-snug truncate" title="<%= log.description || '' %>">
              <%= log.description || (log.meta ? JSON.stringify(log.meta).substring(0, 60) + '…' : '—') %>
            </p>
          </td>

          <!-- IP address -->
          <td class="px-5 py-3 text-xs text-gray-500 font-mono whitespace-nowrap">
            <%= log.ip || '—' %>
          </td>

          <!-- Severity badge -->
          <td class="px-5 py-3">
            <span class="text-xs font-semibold px-2.5 py-1 rounded-full capitalize <%= sc %>">
              <% if (log.severity === 'critical') { %>
              <svg class="w-3 h-3 inline align-middle mr-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <% } %>
              <%= log.severity || 'info' %>
            </span>
          </td>

        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Pagination -->
<% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
<div class="mt-6 flex items-center justify-between">
  <p class="text-sm text-gray-500">
    Showing
    <span class="font-semibold text-gray-900"><%= ((currentPage - 1) * perPage) + 1 %></span>
    –
    <span class="font-semibold text-gray-900"><%= Math.min(currentPage * perPage, totalCount) %></span>
    of
    <span class="font-semibold text-gray-900"><%= totalCount.toLocaleString() %></span>
    entries
  </p>
  <div class="flex items-center space-x-1">

    <!-- First page -->
    <% if (currentPage > 1) { %>
    <a href="?page=1<%= typeof queryString !== 'undefined' && queryString ? '&' + queryString : '' %>"
       class="p-2 rounded-lg text-gray-500 hover:bg-gray-100 transition-colors" title="First">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"/>
      </svg>
    </a>
    <% } %>

    <!-- Previous -->
    <% if (currentPage > 1) { %>
    <a href="?page=<%= currentPage - 1 %><%= typeof queryString !== 'undefined' && queryString ? '&' + queryString : '' %>"
       class="px-3 py-1.5 text-sm rounded-lg text-gray-600 hover:bg-gray-100 transition-colors">Prev</a>
    <% } %>

    <!-- Page numbers -->
    <%
      const pagesAround = 2;
      const startPage   = Math.max(1, currentPage - pagesAround);
      const endPage     = Math.min(totalPages, currentPage + pagesAround);
    %>
    <% if (startPage > 1) { %>
    <span class="px-2 text-gray-400 text-sm">…</span>
    <% } %>
    <% for (let p = startPage; p <= endPage; p++) { %>
    <a href="?page=<%= p %><%= typeof queryString !== 'undefined' && queryString ? '&' + queryString : '' %>"
       class="px-3 py-1.5 text-sm rounded-lg transition-colors <%= p === currentPage ? 'bg-blue-600 text-white font-semibold' : 'text-gray-600 hover:bg-gray-100' %>">
      <%= p %>
    </a>
    <% } %>
    <% if (endPage < totalPages) { %>
    <span class="px-2 text-gray-400 text-sm">…</span>
    <% } %>

    <!-- Next -->
    <% if (currentPage < totalPages) { %>
    <a href="?page=<%= currentPage + 1 %><%= typeof queryString !== 'undefined' && queryString ? '&' + queryString : '' %>"
       class="px-3 py-1.5 text-sm rounded-lg text-gray-600 hover:bg-gray-100 transition-colors">Next</a>
    <% } %>

    <!-- Last page -->
    <% if (currentPage < totalPages) { %>
    <a href="?page=<%= totalPages %><%= typeof queryString !== 'undefined' && queryString ? '&' + queryString : '' %>"
       class="p-2 rounded-lg text-gray-500 hover:bg-gray-100 transition-colors" title="Last">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"/>
      </svg>
    </a>
    <% } %>
  </div>
</div>
<% } %>

<% } %>
