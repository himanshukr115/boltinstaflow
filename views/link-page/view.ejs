<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Social sharing meta tags -->
  <title><%= typeof page !== 'undefined' ? page.title : 'My Links' %> | InstaFlow</title>
  <meta name="description" content="<%= typeof page !== 'undefined' && page.bio ? page.bio : 'Check out my links' %>">

  <!-- Open Graph -->
  <meta property="og:title" content="<%= typeof page !== 'undefined' ? page.title : 'My Links' %>">
  <meta property="og:description" content="<%= typeof page !== 'undefined' && page.bio ? page.bio : 'Check out all my links' %>">
  <meta property="og:image" content="<%= typeof page !== 'undefined' && page.profilePic ? page.profilePic : '/images/default-og.png' %>">
  <meta property="og:type" content="profile">
  <meta property="og:url" content="<%= typeof page !== 'undefined' ? 'https://instaflow.app/l/' + page.slug : '' %>">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="<%= typeof page !== 'undefined' ? page.title : 'My Links' %>">
  <meta name="twitter:description" content="<%= typeof page !== 'undefined' && page.bio ? page.bio : '' %>">
  <meta name="twitter:image" content="<%= typeof page !== 'undefined' && page.profilePic ? page.profilePic : '/images/default-og.png' %>">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/output.css">

  <style>
    :root {
      --bg-color: <%= typeof page !== 'undefined' && page.theme && page.theme.bgColor ? page.theme.bgColor : '#f8fafc' %>;
      --text-color: <%= typeof page !== 'undefined' && page.theme && page.theme.textColor ? page.theme.textColor : '#0f172a' %>;
      --btn-bg: <%= typeof page !== 'undefined' && page.theme && page.theme.btnBg ? page.theme.btnBg : '#2563eb' %>;
      --btn-text: <%= typeof page !== 'undefined' && page.theme && page.theme.btnText ? page.theme.btnText : '#ffffff' %>;
      --btn-radius: <%= typeof page !== 'undefined' && page.theme && page.theme.btnRadius ? page.theme.btnRadius : '12px' %>;
    }
    body { background-color: var(--bg-color); color: var(--text-color); font-family: 'Inter', sans-serif; }
    .link-btn {
      background-color: var(--btn-bg);
      color: var(--btn-text);
      border-radius: var(--btn-radius);
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      padding: 14px 20px;
      font-size: 15px;
      font-weight: 600;
      text-decoration: none;
      transition: opacity 0.15s, transform 0.1s;
      position: relative;
      gap: 10px;
    }
    .link-btn:hover { opacity: 0.9; transform: translateY(-1px); }
    .link-btn:active { transform: translateY(0); }
  </style>
</head>
<body class="min-h-screen flex flex-col">

  <main class="flex-1 flex flex-col items-center justify-start px-4 py-12">
    <div class="w-full max-w-sm mx-auto">

      <!-- Profile Section -->
      <div class="text-center mb-8">
        <% if (typeof page !== 'undefined' && page.profilePic) { %>
          <img
            src="<%= page.profilePic %>"
            alt="<%= page.title %>"
            class="w-24 h-24 rounded-full mx-auto mb-4 object-cover shadow-lg ring-4 ring-white"
          >
        <% } else { %>
          <div class="w-24 h-24 rounded-full mx-auto mb-4 shadow-lg ring-4 ring-white bg-gradient-to-br from-blue-400 to-blue-700 flex items-center justify-center">
            <span class="text-3xl font-bold text-white">
              <%= typeof page !== 'undefined' ? page.title.charAt(0).toUpperCase() : 'I' %>
            </span>
          </div>
        <% } %>

        <h1 class="text-xl font-bold" style="color: var(--text-color)">
          <%= typeof page !== 'undefined' ? page.title : 'My InstaFlow Page' %>
        </h1>

        <% if (typeof page !== 'undefined' && page.username) { %>
          <p class="text-sm opacity-70 mt-0.5">@<%= page.username %></p>
        <% } %>

        <% if (typeof page !== 'undefined' && page.bio) { %>
          <p class="text-sm mt-3 opacity-80 leading-relaxed max-w-xs mx-auto"><%= page.bio %></p>
        <% } %>
      </div>

      <!-- Links -->
      <div class="space-y-3 w-full" id="links-container">
        <% const links = typeof page !== 'undefined' && page.links ? page.links : [
          { label: 'Visit My Website', url: 'https://example.com', icon: 'globe', index: 0 },
          { label: 'Shop My Products', url: 'https://shop.example.com', icon: 'shopping', index: 1 },
          { label: 'Book a Call', url: 'https://calendly.com/example', icon: 'calendar', index: 2 },
          { label: 'My YouTube Channel', url: 'https://youtube.com/@example', icon: 'video', index: 3 },
        ]; %>

        <% links.forEach(function(link, idx) { %>
          <% if (!link.hidden) { %>
            <a
              href="<%= link.url %>"
              target="_blank"
              rel="noopener noreferrer"
              class="link-btn"
              onclick="trackClick(<%= link.index !== undefined ? link.index : idx %>)"
              data-index="<%= link.index !== undefined ? link.index : idx %>"
            >
              <!-- Icon -->
              <% if (link.icon === 'globe') { %>
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
                </svg>
              <% } else if (link.icon === 'shopping') { %>
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                </svg>
              <% } else if (link.icon === 'calendar') { %>
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              <% } else if (link.icon === 'video') { %>
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.82v6.361a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                </svg>
              <% } else { %>
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                </svg>
              <% } %>

              <span><%= link.label %></span>

              <svg class="w-4 h-4 ml-auto opacity-70 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          <% } %>
        <% }); %>
      </div>

      <!-- Social Links (if any) -->
      <% if (typeof page !== 'undefined' && page.socialLinks && page.socialLinks.length > 0) { %>
        <div class="flex items-center justify-center space-x-4 mt-8">
          <% page.socialLinks.forEach(function(social) { %>
            <a href="<%= social.url %>" target="_blank" rel="noopener noreferrer"
              class="w-10 h-10 rounded-full flex items-center justify-center hover:opacity-80 transition-opacity"
              style="background-color: var(--btn-bg); color: var(--btn-text)"
              onclick="trackClick(-1)"
            >
              <span class="text-xs font-bold"><%= social.platform.charAt(0).toUpperCase() %></span>
            </a>
          <% }); %>
        </div>
      <% } %>

      <!-- Powered by footer -->
      <div class="text-center mt-10 pt-6 border-t border-gray-200 border-opacity-30">
        <a href="https://instaflow.app" target="_blank" rel="noopener noreferrer" class="inline-flex items-center space-x-1.5 opacity-50 hover:opacity-80 transition-opacity">
          <div class="w-4 h-4 bg-blue-600 rounded flex items-center justify-center">
            <svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <span class="text-xs font-medium" style="color: var(--text-color)">Made with InstaFlow</span>
        </a>
      </div>
    </div>
  </main>

  <script>
    const pageSlug = '<%= typeof page !== 'undefined' ? page.slug : '' %>';

    function trackClick(index) {
      if (!pageSlug) return;

      // Non-blocking click tracking
      fetch('/l/' + pageSlug + '/click/' + index, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ index: index }),
        keepalive: true
      }).catch(() => {});
    }
  </script>
</body>
</html>
