<%
  layout = 'layouts/main';
  title = 'Manage Subscription';
%>

<div class="max-w-3xl mx-auto">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Manage Subscription</h1>
    <p class="text-gray-500 mt-1">View and manage your InstaFlow subscription</p>
  </div>

  <% const subscription = typeof subscription !== 'undefined' ? subscription : {
    planName: 'Growth Plan',
    status: 'active',
    billingCycle: 'monthly',
    amount: 2499,
    currency: '₹',
    nextBillingDate: new Date(Date.now() + 18*24*60*60*1000),
    startDate: new Date(Date.now() - 12*24*60*60*1000),
    gateway: 'razorpay'
  }; %>

  <!-- Current Plan Card -->
  <div class="card mb-6">
    <div class="flex items-start justify-between mb-5">
      <div class="flex items-center space-x-4">
        <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center">
          <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <div>
          <h2 class="text-lg font-bold text-gray-900"><%= subscription.planName %></h2>
          <div class="flex items-center space-x-2 mt-1">
            <% if (subscription.status === 'active') { %>
              <span class="badge-active">Active</span>
            <% } else if (subscription.status === 'paused') { %>
              <span class="badge-warning">Paused</span>
            <% } else if (subscription.status === 'cancelled') { %>
              <span class="badge-danger">Cancelled</span>
            <% } else { %>
              <span class="badge-inactive">Inactive</span>
            <% } %>
            <span class="text-xs text-gray-400 capitalize"><%= subscription.billingCycle %> billing</span>
          </div>
        </div>
      </div>
      <div class="text-right">
        <p class="text-2xl font-bold text-gray-900">
          <%= subscription.currency %><%= subscription.amount.toLocaleString() %>
        </p>
        <p class="text-xs text-gray-400">/ month</p>
      </div>
    </div>

    <!-- Key Dates -->
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-5 p-4 bg-gray-50 rounded-lg">
      <div>
        <p class="text-xs text-gray-500 font-medium">Started</p>
        <p class="text-sm font-semibold text-gray-900 mt-0.5">
          <%= new Date(subscription.startDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
        </p>
      </div>
      <% if (subscription.status === 'active') { %>
        <div>
          <p class="text-xs text-gray-500 font-medium">Next renewal</p>
          <p class="text-sm font-semibold text-gray-900 mt-0.5">
            <%= new Date(subscription.nextBillingDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
          </p>
        </div>
      <% } %>
      <div>
        <p class="text-xs text-gray-500 font-medium">Payment via</p>
        <p class="text-sm font-semibold text-gray-900 mt-0.5 capitalize"><%= subscription.gateway || 'Razorpay' %></p>
      </div>
    </div>

    <!-- Usage this month -->
    <div class="space-y-3">
      <h3 class="text-sm font-semibold text-gray-700">Usage this month</h3>
      <div>
        <div class="flex justify-between text-sm mb-1">
          <span class="text-gray-600">DMs sent</span>
          <span class="font-medium text-gray-900"><%= typeof usage !== 'undefined' ? usage.dmsUsed.toLocaleString() : '4,280' %> / <%= typeof usage !== 'undefined' ? usage.dmsLimit.toLocaleString() : '10,000' %></span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-2">
          <div class="bg-blue-600 h-2 rounded-full" style="width: <%= typeof usage !== 'undefined' ? Math.min(100, Math.round((usage.dmsUsed / usage.dmsLimit) * 100)) : 43 %>%"></div>
        </div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="flex flex-wrap gap-3 pt-5 mt-5 border-t border-gray-100">
      <a href="/subscription/pricing" class="btn-primary">Upgrade Plan</a>
      <a href="/subscription/pricing" class="btn-secondary">Change Plan</a>
      <% if (subscription.status === 'active') { %>
        <form action="/subscription/pause" method="POST" class="inline">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <button type="submit" class="btn-secondary">Pause Subscription</button>
        </form>
      <% } else if (subscription.status === 'paused') { %>
        <form action="/subscription/resume" method="POST" class="inline">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <button type="submit" class="btn-primary">Resume Subscription</button>
        </form>
      <% } %>
      <% if (subscription.status !== 'cancelled') { %>
        <button
          type="button"
          onclick="document.getElementById('cancel-modal').classList.remove('hidden')"
          class="btn-danger"
        >
          Cancel Subscription
        </button>
      <% } %>
    </div>
  </div>

  <!-- Invoice History -->
  <div class="card">
    <div class="flex items-center justify-between mb-5">
      <h2 class="text-base font-semibold text-gray-900">Invoice History</h2>
      <a href="/subscription/invoices/download-all" class="text-sm text-blue-600 hover:text-blue-700 font-medium flex items-center space-x-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        <span>Download all</span>
      </a>
    </div>

    <% const invoices = typeof invoices !== 'undefined' ? invoices : [
      { _id: 'inv1', date: new Date(Date.now() - 30*24*60*60*1000), planName: 'Growth Plan', amount: 2499, status: 'paid', invoiceUrl: '#' },
      { _id: 'inv2', date: new Date(Date.now() - 60*24*60*60*1000), planName: 'Growth Plan', amount: 2499, status: 'paid', invoiceUrl: '#' },
      { _id: 'inv3', date: new Date(Date.now() - 90*24*60*60*1000), planName: 'Starter Plan', amount: 999, status: 'paid', invoiceUrl: '#' },
    ]; %>

    <% if (invoices.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-gray-100">
              <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide pb-3">Date</th>
              <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide pb-3 hidden sm:table-cell">Plan</th>
              <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide pb-3">Amount</th>
              <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide pb-3">Status</th>
              <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wide pb-3">Invoice</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <% invoices.forEach(function(invoice) { %>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-3 text-sm text-gray-700">
                  <%= new Date(invoice.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                </td>
                <td class="py-3 text-sm text-gray-700 hidden sm:table-cell"><%= invoice.planName %></td>
                <td class="py-3 text-sm font-medium text-gray-900">₹<%= invoice.amount.toLocaleString() %></td>
                <td class="py-3">
                  <% if (invoice.status === 'paid') { %>
                    <span class="badge-active">Paid</span>
                  <% } else if (invoice.status === 'failed') { %>
                    <span class="badge-danger">Failed</span>
                  <% } else { %>
                    <span class="badge-warning">Pending</span>
                  <% } %>
                </td>
                <td class="py-3 text-right">
                  <a href="/subscription/invoices/<%= invoice._id %>/download" class="inline-flex items-center space-x-1 text-sm text-blue-600 hover:text-blue-700">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                    </svg>
                    <span>PDF</span>
                  </a>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="text-sm text-gray-400 text-center py-6">No invoices yet</p>
    <% } %>
  </div>
</div>

<!-- Cancel Subscription Modal -->
<div id="cancel-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black bg-opacity-50" onclick="document.getElementById('cancel-modal').classList.add('hidden')"></div>
  <div class="relative bg-white rounded-xl shadow-xl max-w-md w-full p-6">
    <div class="flex items-center space-x-3 mb-4">
      <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
      </div>
      <div>
        <h3 class="text-lg font-semibold text-gray-900">Cancel Subscription?</h3>
        <p class="text-sm text-gray-500 mt-0.5">Your subscription will remain active until the end of the current billing period.</p>
      </div>
    </div>

    <div class="mb-5 p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
      <p class="text-sm text-yellow-800 font-medium">What happens when you cancel:</p>
      <ul class="mt-2 space-y-1 text-sm text-yellow-700">
        <li>• Automations and campaigns will stop running</li>
        <li>• Your data is preserved for 30 days</li>
        <li>• You can resubscribe at any time</li>
      </ul>
    </div>

    <div class="mb-5">
      <label class="form-label">Tell us why you're cancelling (optional)</label>
      <select id="cancel-reason" class="input-field">
        <option value="">Select a reason...</option>
        <option value="too_expensive">Too expensive</option>
        <option value="missing_features">Missing features I need</option>
        <option value="not_using">Not using it enough</option>
        <option value="switching">Switching to a competitor</option>
        <option value="technical_issues">Technical issues</option>
        <option value="other">Other</option>
      </select>
    </div>

    <div class="flex space-x-3">
      <button type="button" onclick="document.getElementById('cancel-modal').classList.add('hidden')" class="flex-1 btn-secondary">Keep Subscription</button>
      <form action="/subscription/cancel" method="POST" class="flex-1">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <input type="hidden" name="reason" id="cancel-reason-hidden">
        <button type="submit" class="w-full btn-danger" onclick="document.getElementById('cancel-reason-hidden').value = document.getElementById('cancel-reason').value">
          Confirm Cancel
        </button>
      </form>
    </div>
  </div>
</div>
