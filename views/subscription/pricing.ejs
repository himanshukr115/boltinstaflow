<%
  layout = 'layouts/main';
  title = 'Pricing Plans';
%>

<!-- Header -->
<div class="text-center mb-10">
  <h1 class="text-3xl font-bold text-gray-900">Simple, Transparent Pricing</h1>
  <p class="text-gray-500 mt-3 text-lg">Choose the plan that fits your Instagram growth goals</p>

  <!-- Billing Toggle -->
  <div class="flex items-center justify-center space-x-3 mt-6">
    <span class="text-sm font-medium text-gray-700" id="monthly-label">Monthly</span>
    <label class="relative inline-flex items-center cursor-pointer">
      <input type="checkbox" id="billing-toggle" class="sr-only peer">
      <div class="w-12 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
    </label>
    <div class="flex items-center space-x-1.5">
      <span class="text-sm font-medium text-gray-700" id="yearly-label">Yearly</span>
      <span class="bg-green-100 text-green-700 text-xs font-bold px-2 py-0.5 rounded-full">Save 20%</span>
    </div>
  </div>
</div>

<!-- Pricing Cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto mb-14">

  <% const plans = typeof plans !== 'undefined' ? plans : [
    {
      _id: 'starter',
      name: 'Starter',
      priceMonthly: 999,
      priceYearly: 799,
      currency: '₹',
      isPopular: false,
      isActive: true,
      features: ['2,000 DMs/month', '1 Instagram account', '3 automations', '1,000 contacts', 'Basic analytics', 'Email support']
    },
    {
      _id: 'growth',
      name: 'Growth',
      priceMonthly: 2499,
      priceYearly: 1999,
      currency: '₹',
      isPopular: true,
      isActive: true,
      features: ['10,000 DMs/month', '3 Instagram accounts', 'Unlimited automations', '10,000 contacts', 'Advanced analytics', 'Campaign builder', 'Priority support', 'Custom link-in-bio']
    },
    {
      _id: 'pro',
      name: 'Pro',
      priceMonthly: 4999,
      priceYearly: 3999,
      currency: '₹',
      isPopular: false,
      isActive: true,
      features: ['50,000 DMs/month', 'Unlimited accounts', 'Unlimited automations', 'Unlimited contacts', 'Full analytics + export', 'API access', 'Dedicated support', 'White-label option', 'Team collaboration']
    }
  ]; %>

  <% plans.forEach(function(plan) { %>
    <div class="relative <%= plan.isPopular ? 'ring-2 ring-blue-600 shadow-lg' : 'border border-gray-200' %> bg-white rounded-2xl p-6 flex flex-col">

      <% if (plan.isPopular) { %>
        <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
          <span class="bg-blue-600 text-white text-xs font-bold px-4 py-1 rounded-full">MOST POPULAR</span>
        </div>
      <% } %>

      <!-- Plan Header -->
      <div class="mb-5">
        <h3 class="text-lg font-bold text-gray-900"><%= plan.name %></h3>
        <div class="mt-3 flex items-baseline space-x-1">
          <span class="text-sm text-gray-500"><%= plan.currency || '$' %></span>
          <span class="text-4xl font-extrabold text-gray-900 price-value" data-monthly="<%= plan.priceMonthly %>" data-yearly="<%= plan.priceYearly %>">
            <%= plan.priceMonthly %>
          </span>
          <span class="text-gray-500 text-sm">/ month</span>
        </div>
        <div class="yearly-note hidden mt-1">
          <p class="text-xs text-green-600 font-medium">Billed annually &middot; Save <%= plan.currency || '$' %><%= (plan.priceMonthly - plan.priceYearly) * 12 %>/yr</p>
        </div>
      </div>

      <!-- Current plan badge -->
      <% if (typeof userSubscription !== 'undefined' && userSubscription && userSubscription.planId === plan._id.toString()) { %>
        <div class="mb-4 flex items-center space-x-1.5 p-2 bg-green-50 border border-green-200 rounded-lg">
          <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="text-xs font-semibold text-green-700">Your current plan</span>
        </div>
      <% } %>

      <!-- Features -->
      <ul class="space-y-3 mb-6 flex-1">
        <% plan.features.forEach(function(feature) { %>
          <li class="flex items-start space-x-2.5">
            <svg class="w-4 h-4 text-blue-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-sm text-gray-700"><%= feature %></span>
          </li>
        <% }); %>
      </ul>

      <!-- Coupon code -->
      <div class="mb-4">
        <div class="flex space-x-2">
          <input type="text" placeholder="Coupon code" class="input-field text-sm flex-1 coupon-input" data-plan-id="<%= plan._id %>">
          <button type="button" onclick="applyCoupon(this)" class="btn-secondary text-sm px-3 py-2 whitespace-nowrap">Apply</button>
        </div>
        <p class="text-xs text-green-600 hidden mt-1 coupon-success-msg"></p>
        <p class="text-xs text-red-500 hidden mt-1 coupon-error-msg"></p>
      </div>

      <!-- CTA -->
      <% if (typeof userSubscription !== 'undefined' && userSubscription && userSubscription.planId === plan._id.toString()) { %>
        <a href="/subscription" class="block text-center py-2.5 rounded-lg border-2 border-blue-600 text-blue-600 font-semibold text-sm hover:bg-blue-50 transition-colors">
          Manage Plan
        </a>
      <% } else { %>
        <a href="/subscription/checkout?planId=<%= plan._id %>" class="block text-center py-2.5 rounded-lg font-semibold text-sm transition-colors <%= plan.isPopular ? 'btn-primary' : 'border-2 border-gray-300 text-gray-700 hover:border-blue-400 hover:text-blue-600' %>">
          Get Started
        </a>
      <% } %>
    </div>
  <% }); %>
</div>

<!-- Feature Comparison note -->
<div class="max-w-5xl mx-auto mb-14 text-center">
  <p class="text-sm text-gray-500">All plans include: SSL encryption, 99.9% uptime SLA, API compliance, automatic backups</p>
</div>

<!-- FAQ Section -->
<div class="max-w-3xl mx-auto">
  <h2 class="text-2xl font-bold text-gray-900 text-center mb-8">Frequently Asked Questions</h2>
  <div class="space-y-4" id="faq-container">

    <% const faqs = [
      { q: 'Can I change my plan at any time?', a: 'Yes, you can upgrade or downgrade your plan at any time. Upgrades take effect immediately, while downgrades take effect at the end of your current billing period.' },
      { q: 'What happens if I exceed my DM limit?', a: 'When you reach your monthly DM limit, automations and campaigns will pause. You will receive an email alert at 80% usage. You can upgrade your plan to continue sending.' },
      { q: 'Is InstaFlow safe to use with my Instagram account?', a: 'Yes — InstaFlow exclusively uses the official Instagram Graph API. We never use unofficial methods or browser automation that could violate Instagram\'s terms of service.' },
      { q: 'Do you offer refunds?', a: 'We offer a 7-day money-back guarantee for new subscriptions. If you\'re not satisfied, contact support within 7 days of subscribing for a full refund.' },
      { q: 'Can I connect multiple Instagram accounts?', a: 'Yes. The Growth plan supports 3 accounts, and the Pro plan supports unlimited accounts. The Starter plan supports 1 account.' },
      { q: 'What payment methods do you accept?', a: 'We accept UPI, credit/debit cards, net banking, and wallets via Razorpay, and additional payment methods via Cashfree.' },
    ]; %>

    <% faqs.forEach(function(faq, index) { %>
      <div class="border border-gray-200 rounded-xl overflow-hidden faq-item">
        <button
          type="button"
          class="w-full text-left px-6 py-4 flex items-center justify-between hover:bg-gray-50 transition-colors faq-toggle"
          onclick="toggleFaq(this)"
        >
          <span class="text-sm font-semibold text-gray-900"><%= faq.q %></span>
          <svg class="w-4 h-4 text-gray-400 transform transition-transform faq-chevron flex-shrink-0 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="faq-answer hidden px-6 pb-4">
          <p class="text-sm text-gray-600"><%= faq.a %></p>
        </div>
      </div>
    <% }); %>
  </div>
</div>

<script>
  // Billing toggle
  const toggle = document.getElementById('billing-toggle');
  const priceValues = document.querySelectorAll('.price-value');
  const yearlyNotes = document.querySelectorAll('.yearly-note');

  if (toggle) {
    toggle.addEventListener('change', function() {
      const isYearly = this.checked;
      priceValues.forEach(el => {
        el.textContent = isYearly ? el.dataset.yearly : el.dataset.monthly;
      });
      yearlyNotes.forEach(el => {
        el.classList.toggle('hidden', !isYearly);
      });
    });
  }

  // FAQ toggle
  function toggleFaq(btn) {
    const answer = btn.nextElementSibling;
    const chevron = btn.querySelector('.faq-chevron');
    const isOpen = !answer.classList.contains('hidden');
    answer.classList.toggle('hidden', isOpen);
    chevron.classList.toggle('rotate-180', !isOpen);
  }

  // Coupon apply
  async function applyCoupon(btn) {
    const container = btn.closest('.mb-4');
    const input = container.querySelector('.coupon-input');
    const successMsg = container.querySelector('.coupon-success-msg');
    const errorMsg = container.querySelector('.coupon-error-msg');
    const code = input.value.trim();
    const planId = input.dataset.planId;

    if (!code) return;

    try {
      const response = await fetch('/subscription/apply-coupon', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code, planId })
      });
      const data = await response.json();

      if (data.valid) {
        successMsg.textContent = `Coupon applied! ${data.discountText}`;
        successMsg.classList.remove('hidden');
        errorMsg.classList.add('hidden');
        input.classList.add('border-green-500');
      } else {
        errorMsg.textContent = data.message || 'Invalid coupon code';
        errorMsg.classList.remove('hidden');
        successMsg.classList.add('hidden');
        input.classList.add('border-red-500');
      }
    } catch (err) {
      errorMsg.textContent = 'Failed to apply coupon. Try again.';
      errorMsg.classList.remove('hidden');
    }
  }
</script>
