<%
  layout = 'layouts/main';
  title = 'Contacts';
  activePage = 'contacts';
%>

<!-- Page Header -->
<div class="mb-8 flex items-start justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Contacts</h1>
    <p class="text-gray-500 mt-1">Manage your Instagram contacts and segments</p>
  </div>
  <div class="flex items-center space-x-2">
    <button type="button" onclick="document.getElementById('import-modal').classList.remove('hidden')" class="btn-secondary flex items-center space-x-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
      </svg>
      <span class="hidden sm:inline">Import</span>
    </button>
    <a href="/contacts/export" class="btn-secondary flex items-center space-x-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
      </svg>
      <span class="hidden sm:inline">Export CSV</span>
    </a>
  </div>
</div>

<!-- Filters -->
<div class="card mb-5 py-4">
  <div class="flex flex-col sm:flex-row gap-3">
    <div class="relative flex-1">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <input type="text" placeholder="Search by username, name..." class="input-field pl-9" id="contact-search"
        value="<%= typeof query !== 'undefined' && query.search ? query.search : '' %>">
    </div>
    <input type="text" placeholder="Filter by tag..." class="input-field sm:w-36" id="tag-filter"
      value="<%= typeof query !== 'undefined' && query.tag ? query.tag : '' %>">
    <select class="input-field sm:w-48" id="account-filter">
      <option value="">All accounts</option>
      <% if (typeof igAccounts !== 'undefined') { %>
        <% igAccounts.forEach(function(account) { %>
          <option value="<%= account._id %>" <%= typeof query !== 'undefined' && query.igAccount === account._id.toString() ? 'selected' : '' %>>@<%= account.username %></option>
        <% }); %>
      <% } else { %>
        <option value="demo">@my_business_account</option>
      <% } %>
    </select>
    <select class="input-field sm:w-36" id="optin-filter">
      <option value="">DM status: All</option>
      <option value="opted_in">Opted In</option>
      <option value="opted_out">Opted Out</option>
    </select>
  </div>
</div>

<!-- Bulk Actions Bar (shown when contacts selected) -->
<div id="bulk-actions-bar" class="hidden mb-3 flex items-center space-x-3 p-3 bg-blue-50 border border-blue-200 rounded-lg">
  <span class="text-sm font-medium text-blue-800" id="selected-count-text">0 selected</span>
  <div class="flex items-center space-x-2 ml-auto">
    <select class="text-sm border border-blue-300 rounded-lg px-3 py-1.5 text-blue-800 bg-white focus:outline-none" id="bulk-action-select">
      <option value="">Bulk action...</option>
      <option value="add_tag">Add tag</option>
      <option value="remove_tag">Remove tag</option>
      <option value="delete">Delete contacts</option>
      <option value="export">Export selected</option>
    </select>
    <button type="button" onclick="applyBulkAction()" class="btn-primary text-sm py-1.5 px-3">Apply</button>
    <button type="button" onclick="clearSelection()" class="text-sm text-blue-600 hover:text-blue-700">Clear</button>
  </div>
</div>

<% const contacts = typeof contacts !== 'undefined' ? contacts : [
  { _id: '1', username: 'sarah_designs', name: 'Sarah Johnson', profilePic: null, tags: ['lead', 'interested'], firstSeen: new Date(Date.now() - 10*24*60*60*1000), lastInteraction: new Date(Date.now() - 2*60*60*1000), dmOptIn: true },
  { _id: '2', username: 'techguru_99', name: 'Mike Chen', profilePic: null, tags: ['customer'], firstSeen: new Date(Date.now() - 20*24*60*60*1000), lastInteraction: new Date(Date.now() - 1*24*60*60*1000), dmOptIn: true },
  { _id: '3', username: 'fashionista_la', name: 'Emma Wilson', profilePic: null, tags: ['vip', 'customer', 'lead'], firstSeen: new Date(Date.now() - 5*24*60*60*1000), lastInteraction: new Date(Date.now() - 30*60*1000), dmOptIn: false },
  { _id: '4', username: 'fit_journey_2025', name: null, profilePic: null, tags: [], firstSeen: new Date(Date.now() - 1*24*60*60*1000), lastInteraction: new Date(Date.now() - 5*60*1000), dmOptIn: true },
]; %>

<!-- Contacts Table -->
<% if (contacts.length > 0) { %>
  <div class="card p-0 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="border-b border-gray-100 bg-gray-50">
            <th class="px-6 py-3.5 w-10">
              <input type="checkbox" id="select-all" class="w-4 h-4 text-blue-600 rounded border-gray-300 focus:ring-blue-500">
            </th>
            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3.5">Contact</th>
            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3.5 hidden sm:table-cell">Tags</th>
            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3.5 hidden md:table-cell">First Seen</th>
            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3.5 hidden lg:table-cell">Last Interaction</th>
            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3.5">DM</th>
            <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wide px-6 py-3.5">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% contacts.forEach(function(contact) { %>
            <tr class="hover:bg-gray-50 transition-colors contact-row">
              <td class="px-6 py-4">
                <input type="checkbox" class="contact-checkbox w-4 h-4 text-blue-600 rounded border-gray-300 focus:ring-blue-500" data-id="<%= contact._id %>">
              </td>
              <td class="px-4 py-4">
                <div class="flex items-center space-x-3">
                  <div class="w-9 h-9 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center text-white text-sm font-semibold flex-shrink-0">
                    <%= contact.username.charAt(0).toUpperCase() %>
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-gray-900">@<%= contact.username %></p>
                    <% if (contact.name) { %>
                      <p class="text-xs text-gray-500"><%= contact.name %></p>
                    <% } %>
                  </div>
                </div>
              </td>

              <td class="px-4 py-4 hidden sm:table-cell">
                <div class="flex flex-wrap gap-1">
                  <% if (contact.tags && contact.tags.length > 0) { %>
                    <% contact.tags.slice(0, 3).forEach(function(tag) { %>
                      <span class="inline-flex items-center bg-blue-100 text-blue-700 text-xs font-medium px-2 py-0.5 rounded-full"><%= tag %></span>
                    <% }); %>
                    <% if (contact.tags.length > 3) { %>
                      <span class="text-xs text-gray-400">+<%= contact.tags.length - 3 %></span>
                    <% } %>
                  <% } else { %>
                    <span class="text-xs text-gray-400">No tags</span>
                  <% } %>
                </div>
              </td>

              <td class="px-4 py-4 hidden md:table-cell text-sm text-gray-600">
                <%= new Date(contact.firstSeen).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
              </td>

              <td class="px-4 py-4 hidden lg:table-cell text-sm text-gray-600">
                <% const diffMs = Date.now() - new Date(contact.lastInteraction).getTime();
                   const diffMins = Math.round(diffMs / 60000);
                   const diffHours = Math.round(diffMs / 3600000);
                   const diffDays = Math.round(diffMs / 86400000); %>
                <%= diffMins < 60 ? diffMins + ' min ago' : diffHours < 24 ? diffHours + ' hr ago' : diffDays + ' days ago' %>
              </td>

              <td class="px-4 py-4">
                <% if (contact.dmOptIn) { %>
                  <span class="inline-flex items-center space-x-1 bg-green-100 text-green-700 text-xs font-medium px-2 py-0.5 rounded-full">
                    <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    <span>Opted In</span>
                  </span>
                <% } else { %>
                  <span class="badge-inactive text-xs">Opted Out</span>
                <% } %>
              </td>

              <td class="px-6 py-4">
                <div class="flex items-center justify-end space-x-1">
                  <a href="/contacts/<%= contact._id %>" class="p-1.5 rounded-lg text-gray-400 hover:text-blue-600 hover:bg-blue-50 transition-colors" title="View">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                  </a>
                  <button
                    type="button"
                    onclick="window.confirmModal('Delete Contact', 'Remove @<%= contact.username %> from contacts?', function() { document.getElementById('del-contact-<%= contact._id %>').submit(); })"
                    class="p-1.5 rounded-lg text-gray-400 hover:text-red-600 hover:bg-red-50 transition-colors"
                    title="Delete"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                  </button>
                  <form id="del-contact-<%= contact._id %>" action="/contacts/<%= contact._id %>" method="POST" class="hidden">
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                    <input type="hidden" name="_method" value="DELETE">
                  </form>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div class="border-t border-gray-100 px-6 py-4 flex items-center justify-between">
      <p class="text-sm text-gray-500">
        Showing <span class="font-medium">1</span> to <span class="font-medium"><%= contacts.length %></span>
        of <span class="font-medium"><%= typeof pagination !== 'undefined' ? pagination.total : contacts.length %></span> contacts
      </p>
      <% if (typeof pagination !== 'undefined' && pagination.totalPages > 1) { %>
        <div class="flex items-center space-x-1">
          <a href="?page=<%= pagination.currentPage - 1 %>" class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-50 <%= pagination.currentPage <= 1 ? 'opacity-50 pointer-events-none' : '' %>">
            Previous
          </a>
          <% for (let i = Math.max(1, pagination.currentPage - 2); i <= Math.min(pagination.totalPages, pagination.currentPage + 2); i++) { %>
            <a href="?page=<%= i %>" class="px-3 py-1.5 text-sm border rounded-lg <%= i === pagination.currentPage ? 'bg-blue-600 text-white border-blue-600' : 'border-gray-300 text-gray-600 hover:bg-gray-50' %>"><%= i %></a>
          <% } %>
          <a href="?page=<%= pagination.currentPage + 1 %>" class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-50 <%= pagination.currentPage >= pagination.totalPages ? 'opacity-50 pointer-events-none' : '' %>">
            Next
          </a>
        </div>
      <% } %>
    </div>
  </div>
<% } else { %>
  <div class="card text-center py-16">
    <div class="w-20 h-20 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-5">
      <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
      </svg>
    </div>
    <h3 class="text-lg font-semibold text-gray-900 mb-2">No contacts yet</h3>
    <p class="text-gray-500 max-w-md mx-auto">Contacts are automatically added when people interact with your automations. You can also import contacts manually.</p>
  </div>
<% } %>

<!-- Import Modal -->
<div id="import-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black bg-opacity-50" onclick="document.getElementById('import-modal').classList.add('hidden')"></div>
  <div class="relative bg-white rounded-xl shadow-xl max-w-md w-full p-6">
    <div class="flex items-center justify-between mb-5">
      <h3 class="text-lg font-semibold text-gray-900">Import Contacts</h3>
      <button onclick="document.getElementById('import-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <form action="/contacts/import" method="POST" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <div class="mb-4">
        <label class="form-label">CSV file</label>
        <div class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center hover:border-blue-400 transition-colors cursor-pointer" onclick="document.getElementById('import-csv').click()">
          <input type="file" id="import-csv" name="csv" accept=".csv" class="hidden" required>
          <svg class="w-8 h-8 text-gray-400 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
          </svg>
          <p class="text-sm text-gray-600" id="file-label">Click to upload CSV file</p>
          <p class="text-xs text-gray-400 mt-1">Format: username (required), name, tags</p>
        </div>
      </div>
      <p class="text-xs text-gray-400 mb-4">
        <a href="/contacts/import-template.csv" class="text-blue-600 hover:underline">Download template CSV</a>
      </p>
      <div class="flex space-x-3">
        <button type="button" onclick="document.getElementById('import-modal').classList.add('hidden')" class="flex-1 btn-secondary">Cancel</button>
        <button type="submit" class="flex-1 btn-primary">Import</button>
      </div>
    </form>
  </div>
</div>

<script>
  // Select all checkbox
  const selectAll = document.getElementById('select-all');
  const checkboxes = document.querySelectorAll('.contact-checkbox');
  const bulkBar = document.getElementById('bulk-actions-bar');
  const selectedCountText = document.getElementById('selected-count-text');

  function updateBulkBar() {
    const selected = document.querySelectorAll('.contact-checkbox:checked').length;
    if (selected > 0) {
      bulkBar.classList.remove('hidden');
      selectedCountText.textContent = selected + ' selected';
    } else {
      bulkBar.classList.add('hidden');
    }
  }

  if (selectAll) {
    selectAll.addEventListener('change', function() {
      checkboxes.forEach(cb => cb.checked = this.checked);
      updateBulkBar();
    });
  }

  checkboxes.forEach(cb => cb.addEventListener('change', function() {
    const allChecked = Array.from(checkboxes).every(c => c.checked);
    if (selectAll) selectAll.checked = allChecked;
    updateBulkBar();
  }));

  function clearSelection() {
    checkboxes.forEach(cb => cb.checked = false);
    if (selectAll) selectAll.checked = false;
    updateBulkBar();
  }

  function applyBulkAction() {
    const action = document.getElementById('bulk-action-select').value;
    if (!action) return alert('Please select a bulk action');
    const ids = Array.from(document.querySelectorAll('.contact-checkbox:checked')).map(cb => cb.dataset.id);
    if (ids.length === 0) return;
    // Submit to server
    console.log('Bulk action:', action, 'on contacts:', ids);
  }

  // File label update
  document.getElementById('import-csv')?.addEventListener('change', function() {
    document.getElementById('file-label').textContent = this.files[0]?.name || 'Click to upload CSV file';
  });
</script>
