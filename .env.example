# Application
NODE_ENV=development
PORT=3000
APP_NAME=InstaFlow
APP_URL=https://yourdomain.com
APP_SECRET=your-super-secret-key-min-32-chars-long

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/test
MONGODB_URI_REPLICA=mongodb://mongo1:27017,mongo2:27017,mongo3:27017/instaflow?replicaSet=rs0

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_TLS=false

# Session
SESSION_SECRET=your-session-secret-min-32-chars
SESSION_DURATION=86400000

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Instagram / Meta (Official Graph API)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_CALLBACK_URL=https://yourdomain.com/auth/instagram/callback
META_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
META_API_VERSION=v18.0

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Cashfree
CASHFREE_APP_ID=your-cashfree-app-id
CASHFREE_SECRET_KEY=your-cashfree-secret-key
CASHFREE_ENV=PROD
CASHFREE_WEBHOOK_SECRET=your-cashfree-webhook-secret

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=InstaFlow <noreply@yourdomain.com>

# Admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=SecureAdminPassword123!

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./public/uploads

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Monitoring (optional)
SENTRY_DSN=https://xxx@sentry.io/xxx
NEW_RELIC_LICENSE_KEY=your-key
